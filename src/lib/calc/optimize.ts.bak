// ===== 型定義 =====

/** シンプルなステータスブロック型（最適化用） */
type SimpleStatBlock = Record<string, number>;

interface EvaluationContext {
  mode: OptimizeMode;
  targetStat?: InternalStatKey;
  skillId: string;               // スキルID
  skillMultiplier: number;
  hits: number;
  coolTime: number;
  enemyDefense: number;
  enemyTypeResistance: number;
  enemyAttributeResistance: number;
  // 職業・紋章・制約用の追加データ
  jobMaxLevel?: number;
  jobName?: string;              // 職業名（YAML形式）
  jobConst?: JobConstData;       // 職業定数データ
  jobSPData?: JobSPData[];       // 職業SPデータ
  jobBonusPercent?: StatBlock;   // 職業のパーセントボーナス
  spAllocation?: Record<string, number>;  // SP振り分け
  emblem?: EmblemData | null;    // 選択された紋章（nullの場合は自動選択）
  minimumStats?: MinimumStatRequirements;  // 最低必須ステータス
  // ダメージ計算用
  weaponCalc?: WeaponCalcData;   // 武器ダメージ計算データ
  skillCalc?: SkillCalcData;     // スキル計算データ
  // スキル依存ステータス（EX選択用）
  relevantStats?: RelevantStats;
  // ルーンストーンボーナス
  runestoneBonus?: StatBlock;
}

interface ScoredCombination {
  equipmentSet: Record<EquipSlot, CandidateEquipment | null>;
  configIndices: Record<EquipSlot, number>;
  score: number;
  stats: SimpleStatBlock;
}

// ===== ユーティリティ関数 =====

/**
 * 紋章から%ボーナスを抽出
 */
function extractEmblemBonusPercent(emblem: EmblemData | null | undefined): StatBlock {
  if (!emblem) return {};
  return {
    Power: emblem['力（%不要）'] || 0,
    Magic: emblem['魔力（%不要）'] || 0,
    HP: emblem['体力（%不要）'] || 0,
    Mind: emblem['精神（%不要）'] || 0,
    Agility: emblem['素早さ（%不要）'] || 0,
    Dex: emblem['器用（%不要）'] || 0,
    CritDamage: emblem['撃力（%不要）'] || 0,
    Defense: emblem['守備力（%不要）'] || 0,
  };
}

/**
 * 最低必須ステータスを満たしているかチェック
 */
function checkMinimumStats(
  stats: StatBlock | SimpleStatBlock,
  minimumStats: MinimumStatRequirements | undefined
): boolean {
  if (!minimumStats) return true;

  const statKeys = ['HP', 'Power', 'Magic', 'Defense', 'Mind', 'Agility', 'Dex', 'CritDamage'] as const;

  for (const stat of statKeys) {
    const minValue = minimumStats[stat];
    if (minValue !== undefined && minValue > 0) {
      const actualValue = (stats as Record<string, number>)[stat] || 0;
      if (actualValue < minValue) {
        return false;
      }
    }
  }
  return true;
}

/**
 * 最低必須ステータスへの達成度を計算（0.0〜1.0）
 * 全ての最低必須ステータスを満たしている場合は1.0
 * 部分的に満たしている場合はその割合
 */
function calculateMinimumStatsProgress(
  stats: StatBlock | SimpleStatBlock,
  minimumStats: MinimumStatRequirements | undefined
): number {
  if (!minimumStats) return 1.0;

  const statKeys = ['HP', 'Power', 'Magic', 'Defense', 'Mind', 'Agility', 'Dex', 'CritDamage'] as const;
  let totalRequired = 0;
  let totalAchieved = 0;

  for (const stat of statKeys) {
    const minValue = minimumStats[stat];
    if (minValue !== undefined && minValue > 0) {
      totalRequired += minValue;
      const actualValue = (stats as Record<string, number>)[stat] || 0;
      totalAchieved += Math.min(actualValue, minValue); // 超過分はカウントしない
    }
  }

  if (totalRequired === 0) return 1.0;
  return totalAchieved / totalRequired;
}

/**
 * 最低必須ステータスの不足分を計算
 * 各ステータスについて、(必要値 - 現在値)の合計を返す
 */
function calculateMinimumStatsDeficit(
  stats: StatBlock | SimpleStatBlock,
  minimumStats: MinimumStatRequirements | undefined
): number {
  if (!minimumStats) return 0;

  const statKeys = ['HP', 'Power', 'Magic', 'Defense', 'Mind', 'Agility', 'Dex', 'CritDamage'] as const;
  let totalDeficit = 0;

  for (const stat of statKeys) {
    const minValue = minimumStats[stat];
    if (minValue !== undefined && minValue > 0) {
      const actualValue = (stats as Record<string, number>)[stat] || 0;
      const deficit = Math.max(0, minValue - actualValue);
      totalDeficit += deficit;
    }
  }

  return totalDeficit;
}

// ===== 候補プール構築 =====

/**
 * 武器叩き配分パターンを生成（攻撃力/会心率/会心ダメージ）
 */
function generateWeaponSmithingPatterns(maxCount: number): { attackPower: number; critRate: number; critDamage: number }[] {
  const patterns: { attackPower: number; critRate: number; critDamage: number }[] = [];

  // 主要なパターンのみ生成（探索空間削減）
  // 攻撃力全振り
  patterns.push({ attackPower: maxCount, critRate: 0, critDamage: 0 });
  // 会心率全振り
  patterns.push({ attackPower: 0, critRate: maxCount, critDamage: 0 });
  // 会心ダメージ全振り
  patterns.push({ attackPower: 0, critRate: 0, critDamage: maxCount });
  // バランス型
  const third = Math.floor(maxCount / 3);
  patterns.push({ attackPower: third, critRate: third, critDamage: maxCount - third * 2 });
  // 攻撃+会心率
  const half = Math.floor(maxCount / 2);
  patterns.push({ attackPower: half, critRate: maxCount - half, critDamage: 0 });
  // 攻撃+会心ダメージ
  patterns.push({ attackPower: half, critRate: 0, critDamage: maxCount - half });

  return patterns;
}

/**
 * 防具叩き配分を決定
 * スキル依存ステータスと防具の基礎値に基づいて、合計12回を配分
 * @param armor 防具データ
 * @param relevantStats スキル依存ステータス
 * @param maxCount 最大叩き回数（デフォルト12）
 * @param minimumStats 最低必須ステータス（設定されている場合は最優先）
 */
function determineArmorSmithingDistribution(
  armor: ArmorData,
  relevantStats: RelevantStats | undefined,
  maxCount: number = 12,
  minimumStats?: MinimumStatRequirements
): ArmorSmithingDistribution {
  // 防具が持っているステータスを取得（基礎値 > 0）
  const availableStats: { key: keyof ArmorSmithingDistribution; csvKey: string; priority: number }[] = [];

  const statMapping = [
    { key: 'power' as const, csvKey: '力（初期値）', internalKey: 'Power' },
    { key: 'magic' as const, csvKey: '魔力（初期値）', internalKey: 'Magic' },
    { key: 'hp' as const, csvKey: '体力（初期値）', internalKey: 'HP' },
    { key: 'mind' as const, csvKey: '精神（初期値）', internalKey: 'Mind' },
    { key: 'speed' as const, csvKey: '素早さ（初期値）', internalKey: 'Agility' },
    { key: 'dexterity' as const, csvKey: '器用（初期値）', internalKey: 'Dex' },
    { key: 'critDamage' as const, csvKey: '撃力（初期値）', internalKey: 'CritDamage' },
    { key: 'defense' as const, csvKey: '守備力（初期値）', internalKey: 'Defense' },
  ];

  // 防具が持っているステータスのみをフィルタリング
  for (const stat of statMapping) {
    const baseValue = armor[stat.csvKey as keyof ArmorData] as number || 0;
    if (baseValue > 0) {
      // 優先度を決定
      // 1. 最低必須ステータスが設定されている場合は最優先（200）
      // 2. スキル依存ステータスは高優先度（100）
      // 3. 攻撃系ステータスは中優先度（50）
      // 4. その他は低優先度（10）
      const hasMinimumRequirement = minimumStats?.[stat.internalKey as keyof MinimumStatRequirements] !== undefined &&
        (minimumStats[stat.internalKey as keyof MinimumStatRequirements] || 0) > 0;
      const isRelevant = relevantStats?.directStats?.has(stat.internalKey as any) || false;
      const isAttackStat = stat.key === 'power' || stat.key === 'magic' || stat.key === 'critDamage';

      // 最低必須ステータスは最優先
      const priority = hasMinimumRequirement ? 200 : (isRelevant ? 100 : (isAttackStat ? 50 : 10));
      availableStats.push({ key: stat.key, csvKey: stat.csvKey, priority });
    }
  }

  // 利用可能なステータスがない場合は空の配分を返す
  if (availableStats.length === 0) {
    return {};
  }

  // 優先度でソート（高い順）
  availableStats.sort((a, b) => b.priority - a.priority);

  // 配分を決定
  const distribution: ArmorSmithingDistribution = {};
  let remainingCount = maxCount;

  // 優先度が高いステータスに多く配分
  // 最も優先度の高いステータスに全て配分（シンプルな戦略）
  // 複数の高優先度ステータスがある場合は均等配分
  const highPriorityStats = availableStats.filter(s => s.priority === availableStats[0].priority);

  if (highPriorityStats.length === 1) {
    // 1つだけなら全振り
    distribution[highPriorityStats[0].key] = maxCount;
  } else if (highPriorityStats.length === 2) {
    // 2つなら半分ずつ
    const half = Math.floor(maxCount / 2);
    distribution[highPriorityStats[0].key] = half;
    distribution[highPriorityStats[1].key] = maxCount - half;
  } else {
    // 3つ以上なら均等配分
    const each = Math.floor(maxCount / highPriorityStats.length);
    let remaining = maxCount;
    for (let i = 0; i < highPriorityStats.length; i++) {
      if (i === highPriorityStats.length - 1) {
        distribution[highPriorityStats[i].key] = remaining;
      } else {
        distribution[highPriorityStats[i].key] = each;
        remaining -= each;
      }
    }
  }

  return distribution;
}

/** 装備フィルタリング設定 */
const EQUIPMENT_FILTER_CONFIG = {
  // 最低使用可能Lv（これ未満の装備は除外）
  minWeaponLevel: 80,
  minArmorLevel: 60,
  minAccessoryLevel: 60,
  // 最大候補数（使用可能Lv降順で上位N件のみ残す）
  maxWeaponCandidates: 30,
  maxArmorCandidates: 25,
  maxAccessoryCandidates: 20,
};

// ===== 支配性枝刈り（Dominance Pruning） =====

/**
 * 武器Aが武器Bを支配（完全上位互換）しているかチェック
 * すべての主要ステータスでA >= B、かつ少なくとも1つでA > B
 *
 * 使用可能Lv考慮:
 * - Aの使用可能LvがBより低い（または同じ）場合のみ支配関係を認める
 * - Aの使用可能LvがBより高い場合、AはBを支配しない（高Lv装備は使用条件が厳しいため）
 */
function weaponDominates(a: WeaponData, b: WeaponData): boolean {
  // 使用可能Lvが高い装備は低い装備を支配しない
  if (a.使用可能Lv > b.使用可能Lv) {
    return false;
  }

  const statsA = {
    attack: a['攻撃力（初期値）'] || 0,
    critRate: a['会心率（初期値）'] || 0,
    critDamage: a['会心ダメージ（初期値）'] || 0,
    damageCorr: a['ダメージ補正（初期値）'] || 1,
  };
  const statsB = {
    attack: b['攻撃力（初期値）'] || 0,
    critRate: b['会心率（初期値）'] || 0,
    critDamage: b['会心ダメージ（初期値）'] || 0,
    damageCorr: b['ダメージ補正（初期値）'] || 1,
  };

  // すべてのステータスでA >= B
  const allGE = statsA.attack >= statsB.attack &&
                statsA.critRate >= statsB.critRate &&
                statsA.critDamage >= statsB.critDamage &&
                statsA.damageCorr >= statsB.damageCorr;

  if (!allGE) return false;

  // 少なくとも1つでA > B（厳密に上位）
  const anyGT = statsA.attack > statsB.attack ||
                statsA.critRate > statsB.critRate ||
                statsA.critDamage > statsB.critDamage ||
                statsA.damageCorr > statsB.damageCorr;

  return anyGT;
}

/**
 * 防具Aが防具Bを支配（完全上位互換）しているかチェック
 * 使用可能Lvを考慮
 */
function armorDominates(a: ArmorData, b: ArmorData): boolean {
  // 使用可能Lvが高い装備は低い装備を支配しない
  if (a.使用可能Lv > b.使用可能Lv) {
    return false;
  }

  // 主要8ステータスをチェック
  const statKeys = [
    '力（初期値）', '魔力（初期値）', '体力（初期値）', '精神（初期値）',
    '素早さ（初期値）', '器用（初期値）', '撃力（初期値）', '守備力（初期値）'
  ] as const;

  let allGE = true;
  let anyGT = false;

  for (const key of statKeys) {
    const valA = (a[key] as number) || 0;
    const valB = (b[key] as number) || 0;

    if (valA < valB) {
      allGE = false;
      break;
    }
    if (valA > valB) {
      anyGT = true;
    }
  }

  return allGE && anyGT;
}

/**
 * アクセサリーAがアクセサリーBを支配（完全上位互換）しているかチェック
 * 使用可能Lvを考慮
 */
function accessoryDominates(a: AccessoryData, b: AccessoryData): boolean {
  // 使用可能Lvが高い装備は低い装備を支配しない
  if (a.使用可能Lv > b.使用可能Lv) {
    return false;
  }

  // アクセサリーの主要ステータスをチェック
  const statKeys = [
    '力（初期値）', '魔力（初期値）', '体力（初期値）', '精神（初期値）',
    '素早さ（初期値）', '撃力（初期値）'
  ] as const;

  let allGE = true;
  let anyGT = false;

  for (const key of statKeys) {
    const valA = (a[key] as number) || 0;
    const valB = (b[key] as number) || 0;

    if (valA < valB) {
      allGE = false;
      break;
    }
    if (valA > valB) {
      anyGT = true;
    }
  }

  return allGE && anyGT;
}

/**
 * 武器リストから被支配（下位互換）装備を除去
 */
function removeWeaponDominated(weapons: WeaponData[]): WeaponData[] {
  const dominated = new Set<number>();

  for (let i = 0; i < weapons.length; i++) {
    if (dominated.has(i)) continue;

    for (let j = 0; j < weapons.length; j++) {
      if (i === j || dominated.has(j)) continue;

      // weapons[i]がweapons[j]を支配している場合、jを除外
      if (weaponDominates(weapons[i], weapons[j])) {
        dominated.add(j);
      }
    }
  }

  const result = weapons.filter((_, idx) => !dominated.has(idx));
  if (dominated.size > 0) {
    console.log(`[DominancePruning] Weapons: removed ${dominated.size} dominated items`);
  }
  return result;
}

/**
 * 防具リストから被支配（下位互換）装備を除去
 */
function removeArmorDominated(armors: ArmorData[]): ArmorData[] {
  const dominated = new Set<number>();

  for (let i = 0; i < armors.length; i++) {
    if (dominated.has(i)) continue;

    for (let j = 0; j < armors.length; j++) {
      if (i === j || dominated.has(j)) continue;

      if (armorDominates(armors[i], armors[j])) {
        dominated.add(j);
      }
    }
  }

  const result = armors.filter((_, idx) => !dominated.has(idx));
  if (dominated.size > 0) {
    console.log(`[DominancePruning] Armors: removed ${dominated.size} dominated items`);
  }
  return result;
}

/**
 * アクセサリーリストから被支配（下位互換）装備を除去
 */
function removeAccessoryDominated(accessories: AccessoryData[]): AccessoryData[] {
  const dominated = new Set<number>();

  for (let i = 0; i < accessories.length; i++) {
    if (dominated.has(i)) continue;

    for (let j = 0; j < accessories.length; j++) {
      if (i === j || dominated.has(j)) continue;

      if (accessoryDominates(accessories[i], accessories[j])) {
        dominated.add(j);
      }
    }
  }

  const result = accessories.filter((_, idx) => !dominated.has(idx));
  if (dominated.size > 0) {
    console.log(`[DominancePruning] Accessories: removed ${dominated.size} dominated items`);
  }
  return result;
}

/**
 * ビルドAがビルドBを支配（完全上位互換）しているかチェック
 * スコアが同等以上で、全主要ステータスで上位
 */
function buildDominates(statsA: SimpleStatBlock, statsB: SimpleStatBlock, scoreA: number, scoreB: number): boolean {
  // スコアがBより低い場合は支配しない
  if (scoreA < scoreB) {
    return false;
  }

  // 主要ステータスをチェック
  const statKeys = ['Power', 'Magic', 'HP', 'Mind', 'Agility', 'Dex', 'CritDamage', 'Defense'] as const;

  let allGE = true;
  let anyGT = false;

  for (const key of statKeys) {
    const valA = (statsA[key] as number) || 0;
    const valB = (statsB[key] as number) || 0;

    if (valA < valB) {
      allGE = false;
      break;
    }
    if (valA > valB) {
      anyGT = true;
    }
  }

  // スコアが高い場合はステータスチェック不要で支配
  if (scoreA > scoreB && allGE) {
    return true;
  }

  return allGE && anyGT;
}

/**
 * 結果リストから被支配ビルドを除去
 */
function filterDominatedBuilds<T extends { score: number; stats: SimpleStatBlock }>(solutions: T[]): T[] {
  if (solutions.length <= 1) return solutions;

  const dominated = new Set<number>();

  for (let i = 0; i < solutions.length; i++) {
    if (dominated.has(i)) continue;

    for (let j = i + 1; j < solutions.length; j++) {
      if (dominated.has(j)) continue;

      // iがjを支配している場合、jを除外
      if (buildDominates(solutions[i].stats, solutions[j].stats, solutions[i].score, solutions[j].score)) {
        dominated.add(j);
      }
      // jがiを支配している場合、iを除外
      else if (buildDominates(solutions[j].stats, solutions[i].stats, solutions[j].score, solutions[i].score)) {
        dominated.add(i);
        break;
      }
    }
  }

  const result = solutions.filter((_, idx) => !dominated.has(idx));
  if (dominated.size > 0) {
    console.log(`[DominancePruning] Builds: removed ${dominated.size} dominated builds`);
  }
  return result;
}

/**
 * 武器候補プールを構築（固定値使用）
 */
function buildWeaponPool(
  weapons: WeaponData[],
  constraints: OptimizeConstraints,
  availableWeaponTypes: string[],
  selectedWeaponType: string | null,
  eqConst: any
): CandidateEquipment[] {
  const pool: CandidateEquipment[] = [];

  // 固定値：ランクSSS、強化80、叩き12、錬金有効
  const fixedRank: EquipmentRank = OPTIMIZE_FIXED_VALUES.rank;
  const fixedEnhancement = OPTIMIZE_FIXED_VALUES.weaponEnhancement;
  const maxSmithingCount = OPTIMIZE_FIXED_VALUES.maxSmithingCount;
  const alchemyEnabled = OPTIMIZE_FIXED_VALUES.alchemyEnabled;

  // 武器種の決定: selectedWeaponType が指定されていればそれのみ、なければ全availableWeaponTypes
  const targetWeaponTypes = selectedWeaponType
    ? [selectedWeaponType]
    : availableWeaponTypes;

  // "All"を展開
  const expandedWeaponTypes = targetWeaponTypes.includes('All')
    ? ['Sword', 'GreatSword', 'Dagger', 'Axe', 'Spear', 'Bow', 'Wand']
    : targetWeaponTypes;

  // YAML武器種を日本語（CSV形式）に変換
  const csvWeaponTypes = expandedWeaponTypes
    .map(type => WEAPON_TYPE_YAML_TO_CSV[type])
    .filter(Boolean);

  console.log('[buildWeaponPool] csvWeaponTypes:', csvWeaponTypes);
  console.log('[buildWeaponPool] Total weapons in CSV:', weapons.length);

  // 叩き配分パターンを生成
  const smithingPatterns = generateWeaponSmithingPatterns(maxSmithingCount);

  // 事前フィルタリング: 武器種とランクで絞り込み
  const filteredWeapons = weapons.filter(weapon => {
    // 空の装備をスキップ
    if (!weapon.アイテム名 || weapon.アイテム名.trim() === '') {
      return false;
    }

    // 武器種フィルタリング（空の場合は全武器、日本語で比較）
    if (csvWeaponTypes.length > 0 && !csvWeaponTypes.includes(weapon.武器種)) {
      return false;
    }

    // ランク範囲チェック（SSSが使用可能か）
    const minRank = weapon.最低ランク as EquipmentRank | undefined;
    const maxRank = weapon.最高ランク as EquipmentRank | undefined;
    if (minRank && RANK_VALUES[fixedRank] < RANK_VALUES[minRank]) return false;
    if (maxRank && RANK_VALUES[fixedRank] > RANK_VALUES[maxRank]) return false;

    // 最低使用可能Lvチェック
    if (weapon.使用可能Lv < EQUIPMENT_FILTER_CONFIG.minWeaponLevel) {
      return false;
    }

    return true;
  });

  // 使用可能Lv降順でソートして上位N件のみ保持
  filteredWeapons.sort((a, b) => b.使用可能Lv - a.使用可能Lv);
  const topWeapons = filteredWeapons.slice(0, EQUIPMENT_FILTER_CONFIG.maxWeaponCandidates);

  // 支配性枝刈り: 完全上位互換の装備があれば下位互換を除外
  const prunedWeapons = removeWeaponDominated(topWeapons);

  console.log(`[buildWeaponPool] After level filter: ${filteredWeapons.length}, after dominance pruning: ${prunedWeapons.length}`);

  for (const weapon of prunedWeapons) {
    // 各叩きパターンで構成を生成
    const configurations: EquipmentConfiguration[] = smithingPatterns.map(pattern => ({
      rank: fixedRank,
      enhancement: fixedEnhancement,
      smithing: pattern as any,  // WeaponSmithingCounts型
      alchemyEnabled,
    }));

    pool.push({
      id: `weapon_${weapon.アイテム名}`,
      name: weapon.アイテム名,
      type: 'weapon',
      slot: 'weapon',
      sourceData: weapon,
      configurations,
    });
  }

  console.log('[buildWeaponPool] Filtered weapons:', pool.length);
  return pool;
}

/**
 * 最低必須ステータスを考慮したEXパターンを生成
 * 防具とアクセサリーで共通のロジック
 * @param relevantStats スキル依存ステータス
 * @param minimumStats 最低必須ステータス
 * @param equipmentType 装備タイプ（'armor' | 'accessory'）
 */
function generateEXPatternsForMinimumStats(
  relevantStats: RelevantStats | undefined,
  minimumStats: MinimumStatRequirements | undefined,
  equipmentType: 'armor' | 'accessory'
): { ex1: string; ex2: string }[] {
  // 基本パターンを取得
  let exPatterns = relevantStats
    ? getDiverseEXCombinations(relevantStats, equipmentType).map(e => ({
        ex1: e.combination.ex1,
        ex2: e.combination.ex2
      }))
    : [
        { ex1: 'Power', ex2: 'Magic' },
        { ex1: 'Power', ex2: 'CritDamage' },
        { ex1: 'CritDamage', ex2: 'CritDamage' }
      ];

  // 最低必須ステータスが設定されている場合、優先パターンを追加
  if (minimumStats) {
    // 内部キー → EXタイプのマッピング
    // 注: アクセサリーはDefenseのEXを持てない
    const exTypeMapping: Record<string, string | undefined> = {
      'HP': 'HP',
      'Power': 'Power',
      'Magic': 'Magic',
      'Mind': 'Mind',
      'Agility': 'Speed',
      'Dex': 'Dex',
      'CritDamage': 'CritDamage',
      'Defense': equipmentType === 'armor' ? 'Defense' : undefined,
    };

    const requiredExPatterns: { ex1: string; ex2: string }[] = [];

    for (const [statKey, minValue] of Object.entries(minimumStats)) {
      if (minValue !== undefined && minValue > 0) {
        const exType = exTypeMapping[statKey];
        if (exType) {
          // 最低必須ステータス×2のパターン
          requiredExPatterns.push({ ex1: exType, ex2: exType });
          // 最低必須ステータス + ダメージ系のパターン
          requiredExPatterns.push(
            { ex1: exType, ex2: 'Power' },
            { ex1: exType, ex2: 'Magic' },
            { ex1: exType, ex2: 'CritDamage' }
          );
        }
      }
    }

    // 重複を除去して追加
    for (const reqPattern of requiredExPatterns) {
      const exists = exPatterns.some(
        p => p.ex1 === reqPattern.ex1 && p.ex2 === reqPattern.ex2
      );
      if (!exists) {
        exPatterns.push(reqPattern);
      }
    }
  }

  return exPatterns;
}

/**
 * 防具叩き回数パターンを生成
 * 防具の叩きは全ステータスに同時に適用されるため、回数のみを返す
 * calculateArmorStatsがtatakiCountを受け取り、各ステータスに適切な倍率で適用
 */
function generateArmorSmithingCounts(maxCount: number): number[] {
  // 最大回数のみ（0回は常に劣るため除外）
  return [maxCount];
}

/**
 * 防具の複数の叩き配分パターンを生成
 * スキル依存ステータスに基づいて、異なる配分戦略を試行
 * minimumStatsが設定されている場合は、そのステータス優先パターンも生成
 */
function generateArmorSmithingPatterns(
  armor: ArmorData,
  relevantStats: RelevantStats | undefined,
  maxCount: number = 12,
  minimumStats?: MinimumStatRequirements
): ArmorSmithingDistribution[] {
  const patterns: ArmorSmithingDistribution[] = [];

  // 防具が持っているステータスを取得（基礎値 > 0）
  const statMapping = [
    { key: 'power' as const, csvKey: '力（初期値）', internalKey: 'Power' },
    { key: 'magic' as const, csvKey: '魔力（初期値）', internalKey: 'Magic' },
    { key: 'hp' as const, csvKey: '体力（初期値）', internalKey: 'HP' },
    { key: 'mind' as const, csvKey: '精神（初期値）', internalKey: 'Mind' },
    { key: 'speed' as const, csvKey: '素早さ（初期値）', internalKey: 'Agility' },
    { key: 'dexterity' as const, csvKey: '器用（初期値）', internalKey: 'Dex' },
    { key: 'critDamage' as const, csvKey: '撃力（初期値）', internalKey: 'CritDamage' },
    { key: 'defense' as const, csvKey: '守備力（初期値）', internalKey: 'Defense' },
  ];

  // 最低必須ステータスが設定されているステータスのキーを取得
  const requiredStatKeys: (keyof ArmorSmithingDistribution)[] = [];
  if (minimumStats) {
    for (const stat of statMapping) {
      const minValue = minimumStats[stat.internalKey as keyof MinimumStatRequirements];
      if (minValue !== undefined && minValue > 0) {
        // この防具がそのステータスを持っているか確認
        const baseValue = armor[stat.csvKey as keyof ArmorData] as number || 0;
        if (baseValue > 0) {
          requiredStatKeys.push(stat.key);
        }
      }
    }
  }

  // 利用可能なステータスを優先度付きでフィルタリング
  // V2の重み係数（statCoefficients）を使用して優先度を決定
  const availableStats: { key: keyof ArmorSmithingDistribution; priority: number; isRequired: boolean }[] = [];

  for (const stat of statMapping) {
    const baseValue = armor[stat.csvKey as keyof ArmorData] as number || 0;
    if (baseValue > 0) {
      // V2の重み係数から優先度を計算
      const coeff = relevantStats?.statCoefficients?.[stat.internalKey as keyof typeof relevantStats.statCoefficients] || 0;
      const isRelevant = relevantStats?.directStats?.has(stat.internalKey as any) || false;
      const isAttackStat = stat.key === 'power' || stat.key === 'magic' || stat.key === 'critDamage';
      const isRequired = requiredStatKeys.includes(stat.key);

      // V2係数がある場合はそれを優先度として使用（10倍して比較可能に）
      // なければ従来のロジック
      const priority = coeff > 0 ? coeff * 100 : (isRelevant ? 100 : (isAttackStat ? 50 : 10));
      availableStats.push({ key: stat.key, priority, isRequired });
    }
  }

  if (availableStats.length === 0) {
    return [{}];
  }

  // 優先度でソート（ダメージ系優先）
  availableStats.sort((a, b) => b.priority - a.priority);

  // 最低必須ステータスがある場合は、それ用のパターンも追加
  if (requiredStatKeys.length > 0) {
    // パターン: 最低必須ステータス全振り
    for (const reqKey of requiredStatKeys) {
      const reqPattern: ArmorSmithingDistribution = {};
      reqPattern[reqKey] = maxCount;
      patterns.push(reqPattern);
    }

    // パターン: 最低必須ステータス + ダメージ系を混合（半々）
    const topDamageStat = availableStats.find(s => !s.isRequired);
    if (topDamageStat && requiredStatKeys.length === 1) {
      const mixPattern: ArmorSmithingDistribution = {};
      const half = Math.floor(maxCount / 2);
      mixPattern[requiredStatKeys[0]] = half;
      mixPattern[topDamageStat.key] = maxCount - half;
      patterns.push(mixPattern);

      // パターン: 8:4 配分（最低必須8、ダメージ4）
      const mix84Pattern: ArmorSmithingDistribution = {};
      mix84Pattern[requiredStatKeys[0]] = 8;
      mix84Pattern[topDamageStat.key] = 4;
      patterns.push(mix84Pattern);

      // パターン: 4:8 配分（最低必須4、ダメージ8）
      const mix48Pattern: ArmorSmithingDistribution = {};
      mix48Pattern[requiredStatKeys[0]] = 4;
      mix48Pattern[topDamageStat.key] = 8;
      patterns.push(mix48Pattern);
    }
  }

  // パターン1: 最優先ステータス全振り
  const pattern1: ArmorSmithingDistribution = {};
  pattern1[availableStats[0].key] = maxCount;
  patterns.push(pattern1);

  // パターン2: 上位2ステータスが存在する場合、均等配分
  if (availableStats.length >= 2) {
    const pattern2: ArmorSmithingDistribution = {};
    const half = Math.floor(maxCount / 2);
    pattern2[availableStats[0].key] = half;
    pattern2[availableStats[1].key] = maxCount - half;
    patterns.push(pattern2);
  }

  // パターン3: 上位2ステータスが存在する場合、8:4配分
  if (availableStats.length >= 2) {
    const pattern3: ArmorSmithingDistribution = {};
    pattern3[availableStats[0].key] = 8;
    pattern3[availableStats[1].key] = 4;
    patterns.push(pattern3);
  }

  // パターン4: 上位3ステータスが存在する場合、均等配分
  if (availableStats.length >= 3) {
    const pattern4: ArmorSmithingDistribution = {};
    const each = Math.floor(maxCount / 3);
    pattern4[availableStats[0].key] = each;
    pattern4[availableStats[1].key] = each;
    pattern4[availableStats[2].key] = maxCount - each * 2;
    patterns.push(pattern4);
  }

  return patterns;
}

/**
 * 防具候補プールを構築（固定値使用、EX・叩き配分パターン含む）
 */
function buildArmorPool(
  armors: ArmorData[],
  slot: 'head' | 'body' | 'leg',
  constraints: OptimizeConstraints,
  availableArmorTypes: string[],
  eqConst: any,
  relevantStats?: RelevantStats,
  minimumStats?: MinimumStatRequirements
): CandidateEquipment[] {
  const pool: CandidateEquipment[] = [];

  // 固定値：ランクSSS、強化40、叩き12
  const fixedRank: EquipmentRank = OPTIMIZE_FIXED_VALUES.rank;
  const fixedEnhancement = OPTIMIZE_FIXED_VALUES.armorEnhancement;
  const maxSmithingCount = OPTIMIZE_FIXED_VALUES.maxSmithingCount;

  // 部位名のマッピング
  const slotNameMap: Record<string, string> = {
    head: '頭',
    body: '胴',
    leg: '脚',
  };
  const targetSlotName = slotNameMap[slot];

  // YAML防具タイプを日本語（CSV形式）に変換
  const csvArmorTypes = availableArmorTypes
    .map(type => ARMOR_TYPE_YAML_TO_CSV[type])
    .filter(Boolean);

  // 叩き回数パターンを生成（最大回数と0回のみ）
  const smithingCounts = generateArmorSmithingCounts(maxSmithingCount);

  console.log(`[buildArmorPool:${slot}] Looking for armors with types:`, csvArmorTypes);
  console.log(`[buildArmorPool:${slot}] Total armors in CSV:`, armors.length);

  // 事前フィルタリング
  const filteredArmors = armors.filter(armor => {
    // 空の装備をスキップ
    if (!armor.アイテム名 || armor.アイテム名.trim() === '') {
      return false;
    }

    // 部位フィルタリング
    if (armor.部位を選択 !== targetSlotName) return false;

    // 防具タイプフィルタリング（空の場合は全防具、日本語で比較）
    if (csvArmorTypes.length > 0 && !csvArmorTypes.includes(armor.タイプを選択)) {
      return false;
    }

    // ランク範囲チェック（SSSが使用可能か）
    const minRank = armor.最低ランク as EquipmentRank | undefined;
    const maxRank = armor.最高ランク as EquipmentRank | undefined;
    if (minRank && RANK_VALUES[fixedRank] < RANK_VALUES[minRank]) return false;
    if (maxRank && RANK_VALUES[fixedRank] > RANK_VALUES[maxRank]) return false;

    // 最低使用可能Lvチェック
    if (armor.使用可能Lv < EQUIPMENT_FILTER_CONFIG.minArmorLevel) {
      return false;
    }

    return true;
  });

  // 使用可能Lv降順でソートして上位N件のみ保持
  filteredArmors.sort((a, b) => b.使用可能Lv - a.使用可能Lv);
  const topArmors = filteredArmors.slice(0, EQUIPMENT_FILTER_CONFIG.maxArmorCandidates);

  // 支配性枝刈り: 完全上位互換の装備があれば下位互換を除外
  const prunedArmors = removeArmorDominated(topArmors);
  console.log(`[buildArmorPool:${slot}] After level filter: ${filteredArmors.length}, after dominance pruning: ${prunedArmors.length}`);

  // EXパターンを取得（最低必須ステータスを考慮した共通関数を使用）
  const exPatterns = generateEXPatternsForMinimumStats(relevantStats, minimumStats, 'armor');

  for (const armor of prunedArmors) {
    // 叩き配分パターンを生成（防具ごとに利用可能なステータスが異なる）
    const smithingPatterns = generateArmorSmithingPatterns(armor, relevantStats, maxSmithingCount, minimumStats);

    // 叩き配分パターン × EXパターンの組み合わせで構成を生成
    const configurations: EquipmentConfiguration[] = [];

    for (const smithingDist of smithingPatterns) {
      for (const exPattern of exPatterns) {
        configurations.push({
          rank: fixedRank,
          enhancement: fixedEnhancement,
          smithing: { tatakiCount: maxSmithingCount, armorDistribution: smithingDist } as any,
          alchemyEnabled: false,
          exStats: { ex1: exPattern.ex1, ex2: exPattern.ex2 },
        });
      }
    }

    pool.push({
      id: `${slot}_${armor.アイテム名}`,
      name: armor.アイテム名,
      type: 'armor',
      slot,
      sourceData: armor,
      configurations,
    });
  }

  console.log(`[buildArmorPool:${slot}] Filtered armors:`, pool.length);
  return pool;
}

/**
 * アクセサリー候補プールを構築（固定値使用、EXパターン含む）
 */
function buildAccessoryPool(
  accessories: AccessoryData[],
  slot: 'accessory1' | 'accessory2',
  constraints: OptimizeConstraints,
  eqConst: any,
  relevantStats?: RelevantStats,
  minimumStats?: MinimumStatRequirements
): CandidateEquipment[] {
  const pool: CandidateEquipment[] = [];

  // 固定値：ランクSSS
  const fixedRank: EquipmentRank = OPTIMIZE_FIXED_VALUES.rank;

  const slotType = slot === 'accessory1' ? 'ネックレス' : 'ブレスレット';

  console.log(`[buildAccessoryPool:${slot}] Looking for accessories with type:`, slotType);
  console.log(`[buildAccessoryPool:${slot}] Total accessories in CSV:`, accessories.length);

  // EXパターンを取得（最低必須ステータスを考慮した共通関数を使用）
  const exPatterns = generateEXPatternsForMinimumStats(relevantStats, minimumStats, 'accessory');

  // 事前フィルタリング
  const filteredAccessories = accessories.filter(accessory => {
    // 空の装備をスキップ
    if (!accessory.アイテム名 || accessory.アイテム名.trim() === '') {
      return false;
    }

    // タイプフィルタリング
    if (accessory.タイプを選択 !== slotType) return false;

    // ランク範囲チェック（SSSが使用可能か）
    const minRank = accessory.最低ランク as EquipmentRank | undefined;
    const maxRank = accessory.最高ランク as EquipmentRank | undefined;
    if (minRank && RANK_VALUES[fixedRank] < RANK_VALUES[minRank]) return false;
    if (maxRank && RANK_VALUES[fixedRank] > RANK_VALUES[maxRank]) return false;

    // 最低使用可能Lvチェック
    if (accessory.使用可能Lv < EQUIPMENT_FILTER_CONFIG.minAccessoryLevel) {
      return false;
    }

    return true;
  });

  // 使用可能Lv降順でソートして上位N件のみ保持
  filteredAccessories.sort((a, b) => b.使用可能Lv - a.使用可能Lv);
  const topAccessories = filteredAccessories.slice(0, EQUIPMENT_FILTER_CONFIG.maxAccessoryCandidates);

  // 支配性枝刈り: 完全上位互換の装備があれば下位互換を除外
  const prunedAccessories = removeAccessoryDominated(topAccessories);
  console.log(`[buildAccessoryPool:${slot}] After level filter: ${filteredAccessories.length}, after dominance pruning: ${prunedAccessories.length}`);

  for (const accessory of prunedAccessories) {
    // EXパターンごとに構成を生成（防具と同様にex1, ex2の2つ）
    const configurations: EquipmentConfiguration[] = exPatterns.map(exPattern => ({
      rank: fixedRank,
      enhancement: 0,
      smithing: {},
      alchemyEnabled: false,
      exStats: { ex1: exPattern.ex1, ex2: exPattern.ex2 },  // アクセサリーもex1, ex2の2つ
    }));

    pool.push({
      id: `${slot}_${accessory.アイテム名}`,
      name: accessory.アイテム名,
      type: 'accessory',
      slot,
      sourceData: accessory,
      configurations,
    });
  }

  console.log(`[buildAccessoryPool:${slot}] Filtered accessories:`, pool.length);
  return pool;
}

/**
 * 装備プール全体を構築
 */
function buildEquipmentPool(
  gameData: OptimizeGameData,
  constraints: OptimizeConstraints,
  availableWeaponTypes: string[],
  availableArmorTypes: string[],
  selectedWeaponType: string | null,
  relevantStats?: RelevantStats,
  minimumStats?: MinimumStatRequirements
): EquipmentPool {
  const eqConst = gameData.eqConst;

  return {
    weapon: constraints.targetSlots.includes('weapon')
      ? buildWeaponPool(gameData.weapons, constraints, availableWeaponTypes, selectedWeaponType, eqConst)
      : [],
    head: constraints.targetSlots.includes('head')
      ? buildArmorPool(gameData.armors, 'head', constraints, availableArmorTypes, eqConst, relevantStats, minimumStats)
      : [],
    body: constraints.targetSlots.includes('body')
      ? buildArmorPool(gameData.armors, 'body', constraints, availableArmorTypes, eqConst, relevantStats, minimumStats)
      : [],
    leg: constraints.targetSlots.includes('leg')
      ? buildArmorPool(gameData.armors, 'leg', constraints, availableArmorTypes, eqConst, relevantStats, minimumStats)
      : [],
    accessory1: constraints.targetSlots.includes('accessory1')
      ? buildAccessoryPool(gameData.accessories, 'accessory1', constraints, eqConst, relevantStats, minimumStats)
      : [],
    accessory2: constraints.targetSlots.includes('accessory2')
      ? buildAccessoryPool(gameData.accessories, 'accessory2', constraints, eqConst, relevantStats, minimumStats)
      : [],
  };
}

// ===== 評価関数 =====

/** EXタイプ定義（防具用） */
type ArmorEXType = 'Dex' | 'CritDamage' | 'Speed' | 'HP' | 'Power' | 'Magic' | 'Mind' | 'Defense';
/** EXタイプ定義（アクセサリー用） */
type AccessoryEXType = 'Dex' | 'CritDamage' | 'Speed' | 'HP' | 'Power' | 'Magic' | 'Mind';

/** EXタイプ → ステータスキーのマッピング */
const EX_TYPE_TO_STAT_KEY: Record<string, string> = {
  'Power': 'Power',
  'Magic': 'Magic',
  'HP': 'HP',
  'Mind': 'Mind',
  'Speed': 'Agility',
  'Dex': 'Dex',
  'CritDamage': 'CritDamage',
  'Defense': 'Defense',
};

/**
 * 装備のステータスを計算（既存のequipmentCalculator関数を使用）
 * EXステータスも計算（1装備につき2スロット）
 */
function calculateEquipmentStatsFn(
  candidate: CandidateEquipment,
  configIndex: number,
  eqConst: EqConstData,
  relevantStats?: RelevantStats
): SimpleStatBlock {
  const config = candidate.configurations[configIndex];
  if (!config) return {};

  const stats: SimpleStatBlock = {};

  try {
    if (candidate.type === 'weapon') {
      const weapon = candidate.sourceData as WeaponData;
      // 武器叩き配分を取得
      const smithing = config.smithing as { attackPower?: number; critRate?: number; critDamage?: number } || {};
      const weaponSmithing = {
        attackPower: smithing.attackPower || 0,
        critRate: smithing.critRate || 0,
        critDamage: smithing.critDamage || 0,
      };

      const weaponStats = calculateWeaponStats(
        weapon,
        config.rank as any,
        config.enhancement,
        weaponSmithing,
        config.alchemyEnabled,
        eqConst
      );

      // 武器固有ステータスをマッピング
      stats.WeaponAttackPower = weaponStats.attackPower || 0;
      stats.CritRate = weaponStats.critRate || 0;
      stats.CritDamage = weaponStats.critDamage || 0;
      stats.CoolTime = weaponStats.coolTime || 0;
      stats.DamageCorrection = weaponStats.damageCorrection || 1;
    } else if (candidate.type === 'armor') {
      const armor = candidate.sourceData as ArmorData;
      // 叩き配分を取得または決定
      const smithing = config.smithing as { armorDistribution?: ArmorSmithingDistribution; tatakiCount?: number } || {};

      // 叩き配分が指定されていない場合は自動決定
      let armorDistribution: ArmorSmithingDistribution;
      if (smithing.armorDistribution) {
        armorDistribution = smithing.armorDistribution;
      } else if (smithing.tatakiCount && smithing.tatakiCount > 0) {
        // 従来のtatakiCountが指定されている場合は自動配分
        armorDistribution = determineArmorSmithingDistribution(armor, relevantStats, smithing.tatakiCount);
      } else {
        armorDistribution = {};
      }

      const armorStats = calculateArmorStats(
        armor,
        config.rank as any,
        config.enhancement,
        armorDistribution,
        eqConst
      );

      // 防具ステータスをマッピング
      if (armorStats.final) {
        stats.Power = armorStats.final.power || 0;
        stats.Magic = armorStats.final.magic || 0;
        stats.HP = armorStats.final.hp || 0;
        stats.Mind = armorStats.final.mind || 0;
        stats.Agility = armorStats.final.speed || 0;
        stats.Dex = armorStats.final.dexterity || 0;
        stats.CritDamage = (stats.CritDamage || 0) + (armorStats.final.critDamage || 0);
        stats.Defense = armorStats.final.defense || 0;
      }

      // 防具叩き内訳を追跡（実際の配分を表示）
      const totalTataki = Object.values(armorDistribution).reduce((sum, v) => sum + (v || 0), 0);
      if (totalTataki > 0) {
        // 配分を日本語名に変換
        const statNameMap: Record<string, string> = {
          power: '力',
          magic: '魔力',
          hp: '体力',
          mind: '精神',
          speed: '素早さ',
          dexterity: '器用',
          critDamage: '撃力',
          defense: '守備力',
        };

        const smithingDetails: { stat: string; count: number }[] = [];
        for (const [key, count] of Object.entries(armorDistribution)) {
          if (count && count > 0) {
            smithingDetails.push({ stat: statNameMap[key] || key, count });
          }
        }

        stats._smithingBreakdown = {
          totalCount: totalTataki,
          details: smithingDetails,
        } as any;
      }

      // 防具EX計算（2スロット）
      // 構成にexStatsが含まれている場合はそれを使用、なければrelevantStatsから自動選択
      let ex1Type: ArmorEXType;
      let ex2Type: ArmorEXType;

      if (config.exStats?.ex1 && config.exStats?.ex2) {
        ex1Type = config.exStats.ex1 as ArmorEXType;
        ex2Type = config.exStats.ex2 as ArmorEXType;
      } else if (relevantStats) {
        const exSelection = selectOptimalEX(relevantStats, 'armor');
        ex1Type = exSelection.ex1 as ArmorEXType;
        ex2Type = exSelection.ex2 as ArmorEXType;
      } else {
        // デフォルト
        ex1Type = 'Power';
        ex2Type = 'Magic';
      }

      try {
        const exResult = calculateArmorEX(
          armor,
          config.rank as any,
          ex1Type,
          ex2Type,
          eqConst
        );

        // EX値をstatsに加算
        const ex1StatKey = EX_TYPE_TO_STAT_KEY[ex1Type];
        const ex2StatKey = EX_TYPE_TO_STAT_KEY[ex2Type];

        if (ex1StatKey) {
          stats[ex1StatKey] = (stats[ex1StatKey] || 0) + exResult.ex1;
        }
        if (ex2StatKey) {
          stats[ex2StatKey] = (stats[ex2StatKey] || 0) + exResult.ex2;
        }

        // EX選択情報を記録（デバッグ用）
        stats._ex1Type = ex1Type as any;
        stats._ex1Value = exResult.ex1;
        stats._ex2Type = ex2Type as any;
        stats._ex2Value = exResult.ex2;
      } catch (exError) {
        console.warn('[calculateEquipmentStatsFn] Armor EX calculation failed:', exError);
      }
    } else if (candidate.type === 'accessory') {
      const accessory = candidate.sourceData as AccessoryData;

      const accessoryStats = calculateAccessoryStats(
        accessory,
        config.rank as any,
        eqConst
      );

      // アクセサリーステータスをマッピング
      if (accessoryStats.final) {
        stats.Power = (stats.Power || 0) + (accessoryStats.final.power || 0);
        stats.Magic = (stats.Magic || 0) + (accessoryStats.final.magic || 0);
        stats.HP = (stats.HP || 0) + (accessoryStats.final.hp || 0);
        stats.Mind = (stats.Mind || 0) + (accessoryStats.final.mind || 0);
        stats.Agility = (stats.Agility || 0) + (accessoryStats.final.speed || 0);
        stats.Dex = (stats.Dex || 0) + (accessoryStats.final.dexterity || 0);
        stats.CritDamage = (stats.CritDamage || 0) + (accessoryStats.final.critDamage || 0);
      }

      // アクセサリーEX計算（2スロット）- 防具と同様に2つのEXが付与される
      // 構成にexStatsが含まれている場合はそれを使用、なければrelevantStatsから自動選択
      let ex1Type: AccessoryEXType;
      let ex2Type: AccessoryEXType;

      if (config.exStats?.ex1 && config.exStats?.ex2) {
        ex1Type = config.exStats.ex1 as AccessoryEXType;
        ex2Type = config.exStats.ex2 as AccessoryEXType;
      } else if (relevantStats) {
        const exSelection = selectOptimalEX(relevantStats, 'accessory');
        ex1Type = exSelection.ex1 as AccessoryEXType;
        ex2Type = exSelection.ex2 as AccessoryEXType;
      } else {
        // デフォルト
        ex1Type = 'Power';
        ex2Type = 'Magic';
      }

      try {
        // アクセサリーは2つのEXを計算（防具と同様）
        const exResult = calculateAccessoryEX(
          accessory,
          config.rank as any,
          ex1Type,
          ex2Type,
          eqConst
        );

        // EX1値をstatsに加算
        const ex1StatKey = EX_TYPE_TO_STAT_KEY[ex1Type];
        if (ex1StatKey) {
          stats[ex1StatKey] = (stats[ex1StatKey] || 0) + exResult.ex1;
        }

        // EX2値をstatsに加算
        const ex2StatKey = EX_TYPE_TO_STAT_KEY[ex2Type];
        if (ex2StatKey) {
          stats[ex2StatKey] = (stats[ex2StatKey] || 0) + exResult.ex2;
        }

        // EX選択情報を記録（デバッグ用）
        stats._ex1Type = ex1Type as any;
        stats._ex1Value = exResult.ex1;
        stats._ex2Type = ex2Type as any;
        stats._ex2Value = exResult.ex2;
      } catch (exError) {
        console.warn('[calculateEquipmentStatsFn] Accessory EX calculation failed:', exError);
      }
    }
  } catch (error) {
    // エラー時はフォールバック（簡略計算）
    console.warn('Equipment calculation error, using fallback:', error);

    if (candidate.type === 'weapon') {
      const weapon = candidate.sourceData as WeaponData;
      const baseAttack = weapon['攻撃力（初期値）'] || 0;
      const rankBonus = RANK_VALUES[config.rank] * 10;
      const enhanceBonus = config.enhancement * 2;
      stats.WeaponAttackPower = baseAttack + rankBonus + enhanceBonus;
      stats.CritRate = weapon['会心率（初期値）'] || 0;
      stats.CritDamage = weapon['会心ダメージ（初期値）'] || 0;
    } else if (candidate.type === 'armor') {
      const armor = candidate.sourceData as ArmorData;
      stats.Power = armor['力（初期値）'] || 0;
      stats.Magic = armor['魔力（初期値）'] || 0;
      stats.HP = armor['体力（初期値）'] || 0;
      stats.Defense = armor['守備力（初期値）'] || 0;
    } else if (candidate.type === 'accessory') {
      const accessory = candidate.sourceData as AccessoryData;
      stats.Power = accessory['力（初期値）'] || 0;
      stats.Magic = accessory['魔力（初期値）'] || 0;
    }
  }

  return stats;
}

/** CSV武器種 → WeaponType（英語小文字） */
const CSV_WEAPON_TO_TYPE: Record<string, WeaponType> = {
  '剣': 'sword',
  '大剣': 'greatsword',
  '短剣': 'dagger',
  '斧': 'axe',
  '槍': 'spear',
  '弓': 'bow',
  '杖': 'wand',
};

/**
 * 組み合わせを評価してスコアを計算
 * ビルドツールと同じ計算ロジック（calculateDamage）を使用
 */
function evaluateCombination(
  combination: Record<EquipSlot, CandidateEquipment | null>,
  configIndices: Record<EquipSlot, number>,
  context: EvaluationContext,
  eqConst: EqConstData
): { score: number; stats: SimpleStatBlock; meetsMinimum: boolean } {
  // 全装備のステータスを合計
  const equipmentStats: SimpleStatBlock = {};
  const slots: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];

  // 武器固有の値を保存
  let weaponCritRate = 0;
  let weaponCritDamage = 0;
  let weaponCoolTime = 5;
  let weaponDamageCorrection = 1;
  let weaponAttackPower = 0;
  let weaponType: WeaponType = 'sword';  // デフォルト

  for (const slot of slots) {
    const candidate = combination[slot];
    if (!candidate) continue;

    const configIndex = configIndices[slot] || 0;
    const stats = calculateEquipmentStatsFn(candidate, configIndex, eqConst, context.relevantStats);

    // 武器固有の値を取得
    if (slot === 'weapon') {
      weaponCritRate = stats.CritRate || 0;
      weaponCritDamage = stats.CritDamage || 0;
      weaponCoolTime = stats.CoolTime || 5;
      weaponDamageCorrection = stats.DamageCorrection || 1;
      weaponAttackPower = stats.WeaponAttackPower || 0;

      // 武器種を取得
      const weaponData = candidate.sourceData as WeaponData;
      const csvWeaponType = weaponData.武器種;
      weaponType = CSV_WEAPON_TO_TYPE[csvWeaponType] || 'sword';
    }

    // 装備ステータスを合計（武器固有のステータスは除外）
    // 注: 武器のCritDamageは武器専用のweaponCritDamageとして別管理するため除外
    for (const [key, value] of Object.entries(stats)) {
      if (typeof value === 'number' &&
          key !== 'WeaponAttackPower' &&
          key !== 'CoolTime' &&
          key !== 'DamageCorrection' &&
          key !== 'CritRate') {
        // 武器スロットの場合、CritDamageは除外（weaponCritDamageとして管理）
        if (slot === 'weapon' && key === 'CritDamage') {
          continue;
        }
        equipmentStats[key] = (equipmentStats[key] || 0) + value;
      }
    }
  }

  // 職業ステータスを計算（calculateAllJobStatsを使用）
  const jobLevel = context.jobMaxLevel || 100;
  const emblemBonusPercent = extractEmblemBonusPercent(context.emblem);

  // 職業ステータスを取得
  let jobStats: StatBlock = {
    HP: jobLevel,
    Power: jobLevel * 2,
    Magic: jobLevel * 2,
    Mind: jobLevel,
    Agility: 0,
    Dex: 0,
    CritDamage: 0,
    Defense: 0,
  };
  let jobBonusPercent: StatBlock = {};

  // SP振り分けをSPAllocation形式に変換（"A-1" -> { branch: 'A', tier: 1, spCost: X }）
  // 注意: CSVの「必要SP」は累積SPなので、各ノード単体のコストに変換する必要がある
  type SPAllocationItem = { branch: 'A' | 'B' | 'C'; tier: number; spCost: number };
  const spAllocationArray: SPAllocationItem[] = [];
  if (context.spAllocation && context.jobSPData) {
    // まず有効なノードを収集してソート
    const sortedAllocations: Array<{nodeId: string; branch: string; tier: number}> = [];

    for (const [nodeId, level] of Object.entries(context.spAllocation)) {
      if (level > 0) {
        const match = nodeId.match(/^([A-C])-(\d+)$/);
        if (match) {
          sortedAllocations.push({
            nodeId,
            branch: match[1],
            tier: parseInt(match[2])
          });
        }
      }
    }

    // ブランチとティアでソート（A-1, A-2, ..., B-1, B-2, ...）
    sortedAllocations.sort((a, b) => {
      if (a.branch !== b.branch) return a.branch.localeCompare(b.branch);
      return a.tier - b.tier;
    });

    // ブランチごとの前のティアの累積SPを追跡
    const prevRequiredSP: Record<string, number> = { A: 0, B: 0, C: 0 };

    for (const alloc of sortedAllocations) {
      const tierData = context.jobSPData.find(row => row.解法段階 === alloc.nodeId);
      const requiredSP = tierData
        ? (typeof tierData.必要SP === 'string' ? parseFloat(tierData.必要SP) || 0 : tierData.必要SP || 0)
        : 0;
      // 単体コスト = 現在の累積必要SP - 前のティアの累積必要SP
      const spCost = requiredSP - prevRequiredSP[alloc.branch];
      prevRequiredSP[alloc.branch] = requiredSP;

      spAllocationArray.push({
        branch: alloc.branch as 'A' | 'B' | 'C',
        tier: alloc.tier,
        spCost
      });
    }
  }

  // SPから得られるステータスを計算
  let spStats: StatBlock = {};

  if (context.jobName && context.jobConst) {
    try {
      // 実際の職業ステータスを計算（SP振り分け含む）
      const calculatedJobStats = calculateAllJobStats(
        context.jobName,
        jobLevel,
        spAllocationArray,  // SP振り分けを渡す
        context.jobConst,
        context.jobSPData
      );
      jobStats = calculatedJobStats;

      // 職業補正(%)を取得
      if (context.jobSPData && context.jobSPData.length > 0) {
        const spTree = convertToSPTree(context.jobSPData);
        if (spTree.jobCorrection) {
          // 注: convertToSPTreeは大文字キー（Power, Magic等）を使用
          jobBonusPercent = {
            Power: spTree.jobCorrection.Power || 0,
            Magic: spTree.jobCorrection.Magic || 0,
            HP: spTree.jobCorrection.HP || 0,
            Mind: spTree.jobCorrection.Mind || 0,
            Agility: spTree.jobCorrection.Agility || 0,
            Dex: spTree.jobCorrection.Dex || 0,
            CritDamage: spTree.jobCorrection.CritDamage || 0,
            Defense: spTree.jobCorrection.Defense || 0,
          };
        }

        // SPから得られるステータスを計算
        if (spTree.spNodes && spAllocationArray.length > 0) {
          for (const allocation of spAllocationArray) {
            const node = spTree.spNodes.find(n => n.branch === allocation.branch && n.tier === allocation.tier);
            if (node && node.stats) {
              for (const [key, value] of Object.entries(node.stats)) {
                if (typeof value === 'number') {
                  spStats[key as keyof StatBlock] = ((spStats[key as keyof StatBlock] as number) || 0) + value;
                }
              }
            }
          }
        }
      }
    } catch (e) {
      console.warn('[evaluateCombination] calculateAllJobStats failed:', e);
    }
  }

  const statusInput: StatusCalcInput = {
    jobStats: {
      initial: jobStats,
      sp: spStats,  // SP振りを反映
      bonusPercent: context.jobBonusPercent || jobBonusPercent,
    },
    jobLevel,
    equipmentTotal: equipmentStats,
    emblemBonusPercent,
    weaponCritRate,
    runestoneBonus: context.runestoneBonus,  // ルーンストーンボーナス
  };

  // calculateStatusを呼び出し
  const calcResult = calculateStatus(statusInput);

  // CalcResult型を処理（成功/失敗の判定）
  let finalStats: StatBlock = {};
  if (calcResult.success) {
    finalStats = calcResult.data.final || {};
  } else {
    console.warn('[evaluateCombination] calculateStatus failed:', calcResult.error);
  }

  // 注: 武器の会心ダメージと、キャラクターの撃力（防具・アクセサリー・職業から）は分離して管理
  // - weaponCritDamage: 武器固有の会心ダメージ（WeaponCritDamageとして計算式に使用）
  // - finalStats.CritDamage: キャラクターの撃力（UserCritDamageとして計算式に使用）

  // 最低必須ステータスのチェック
  // DEBUG: 最低必須ステータスが設定されている場合、ステータスを確認
  if (context.minimumStats?.Defense && context.minimumStats.Defense > 0) {
    console.log('[evaluateCombination] minimumStats.Defense:', context.minimumStats.Defense);
    console.log('[evaluateCombination] equipmentStats.Defense:', equipmentStats.Defense);
    console.log('[evaluateCombination] finalStats.Defense:', finalStats.Defense);
  }
  const meetsMinimum = checkMinimumStats(finalStats, context.minimumStats);

  // スコア計算
  let score = 0;

  switch (context.mode) {
    case 'damage':
    case 'dps': {
      // calculateDamageを使用してダメージ計算
      if (context.weaponCalc && context.skillCalc) {
        // CalculatedStats型を構築
        const calculatedStats: CalculatedStats = {
          breakdown: {
            equipment: equipmentStats,
            jobInitial: jobStats,
            jobSP: {},
            food: {},
            userOption: {},
          },
          base: finalStats,
          bonusPercent: {
            job: jobBonusPercent,
            emblem: emblemBonusPercent,
            total: {},
          },
          final: finalStats,
          critRate: weaponCritRate,  // 会心率
        };

        const damageInput: DamageCalcInput = {
          weaponType,
          weaponAttackPower,
          weaponCritRate,
          weaponCritDamage,  // 武器固有の会心ダメージのみ（キャラクター撃力はUserCritDamageで参照）
          damageCorrection: weaponDamageCorrection,
          userStats: calculatedStats,
          jobName: context.jobName,
          enemy: {
            defense: context.enemyDefense,
            typeResistance: context.enemyTypeResistance,
            attributeResistance: context.enemyAttributeResistance,
          },
          options: {
            damageCorrectionMode: 'avg',
            critMode: 'expected',
            skillName: context.skillId,
          },
        };

        const damageResult = calculateDamage(damageInput, context.weaponCalc, context.skillCalc);

        if (damageResult.success) {
          if (context.mode === 'damage') {
            score = damageResult.data.finalDamage;
          } else {
            // DPS = ダメージ / CT
            const ct = damageResult.data.ct || context.coolTime || 1;
            score = damageResult.data.finalDamage / Math.max(ct, 1);
          }
        } else {
          console.warn('[evaluateCombination] calculateDamage failed:', damageResult.error?.message || 'Unknown error');
        }
      } else {
        // フォールバック：簡易計算（weaponCalc/skillCalcがない場合）
        const mainStat = Math.max(finalStats.Power || 0, finalStats.Magic || 0);
        const baseDamage = (weaponAttackPower + mainStat) * weaponDamageCorrection * context.skillMultiplier;
        // 会心ダメージは武器+キャラクターの合計を使用
        const totalCritDamageForFallback = weaponCritDamage + (finalStats.CritDamage || 0);
        const critMultiplier = 1 + (weaponCritRate / 100) * (totalCritDamageForFallback / 100);
        score = baseDamage * critMultiplier * context.hits;

        if (context.mode === 'dps') {
          const ct = Math.max(weaponCoolTime + context.coolTime, 1);
          score = score / ct;
        }
      }
      break;
    }

    case 'stat': {
      // ステータス最大化
      if (context.targetStat) {
        score = finalStats[context.targetStat] || 0;
      }
      break;
    }
  }

  // 最低必須ステータスを満たさない場合はペナルティ
  if (!meetsMinimum) {
    score = 0;
  }

  // 結果ステータスを返す（内部キーを含む）
  // 表示用の合計会心ダメージ（武器+キャラクター）
  const displayCritDamage = weaponCritDamage + (finalStats.CritDamage || 0);
  const resultStats: SimpleStatBlock = {
    ...finalStats,
    WeaponAttackPower: weaponAttackPower,
    CritRate: weaponCritRate,
    CritDamage: displayCritDamage,  // 表示用の合計値
    WeaponCritDamage: weaponCritDamage,  // 武器の会心ダメージ（参考用）
    CoolTime: weaponCoolTime,
    DamageCorrection: weaponDamageCorrection,
  };

  return { score, stats: resultStats, meetsMinimum };
}

// ===== 探索アルゴリズム =====

/** 全探索の閾値（組み合わせ数がこれ以下なら全探索） */
const EXHAUSTIVE_SEARCH_THRESHOLD = 10000;

/** 解リストの最大サイズ（メモリ節約のため） */
const MAX_SOLUTIONS_IN_MEMORY = 200;

// ===== 評価キャッシュ（Option B） =====
/** 評価結果のキャッシュ（同じ装備構成の再評価を回避） */
const evaluationCache = new Map<string, { score: number; stats: SimpleStatBlock; meetsMinimum: boolean }>();

/** キャッシュをクリア（新しい最適化開始時に呼び出し） */
function clearEvaluationCache(): void {
  evaluationCache.clear();
}

/** キャッシュキーを生成 */
function generateCacheKey(
  combination: Record<EquipSlot, CandidateEquipment | null>,
  configIndices: Record<EquipSlot, number>,
  contextKey: string  // emblem + runestoneの組み合わせを識別
): string {
  const slots: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];
  const parts = slots.map(slot => {
    const cand = combination[slot];
    if (!cand) return `${slot}:null`;
    const cfgIdx = configIndices[slot] || 0;
    const cfg = cand.configurations[cfgIdx];
    const exStr = cfg?.exStats ? `${cfg.exStats.ex1}-${cfg.exStats.ex2 || ''}` : '';
    const smithStr = cfg?.smithing ? JSON.stringify(cfg.smithing) : '';
    return `${slot}:${cand.id}:${cfgIdx}:${exStr}:${smithStr}`;
  });
  return `${contextKey}|${parts.join('|')}`;
}

/** キャッシュ付き評価関数 */
function evaluateCombinationCached(
  combination: Record<EquipSlot, CandidateEquipment | null>,
  configIndices: Record<EquipSlot, number>,
  context: EvaluationContext,
  eqConst: EqConstData,
  contextKey: string
): { score: number; stats: SimpleStatBlock; meetsMinimum: boolean } {
  const cacheKey = generateCacheKey(combination, configIndices, contextKey);

  const cached = evaluationCache.get(cacheKey);
  if (cached) {
    return cached;  // キャッシュヒット
  }

  // キャッシュミス：実際に評価
  const result = evaluateCombination(combination, configIndices, context, eqConst);
  evaluationCache.set(cacheKey, result);
  return result;
}

/**
 * 全探索で最適解を探す（非同期版 - UIスレッド解放あり）
 * 組み合わせ数が閾値以下の場合に使用
 */
async function exhaustiveSearchAsync(
  pool: EquipmentPool,
  context: EvaluationContext,
  eqConst: any,
  maxResults: number = 10
): Promise<ScoredCombination[]> {
  const slots: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];
  const solutions: ScoredCombination[] = [];

  // 各スロットの候補と構成インデックスを列挙
  const slotOptions: Array<Array<{ candidate: CandidateEquipment | null; configIndex: number }>> = [];

  for (const slot of slots) {
    const options: Array<{ candidate: CandidateEquipment | null; configIndex: number }> = [];
    const candidates = pool[slot];

    if (candidates.length === 0) {
      options.push({ candidate: null, configIndex: 0 });
    } else {
      for (const candidate of candidates) {
        for (let configIdx = 0; configIdx < candidate.configurations.length; configIdx++) {
          options.push({ candidate, configIndex: configIdx });
        }
      }
    }
    slotOptions.push(options);
  }

  // 全組み合わせを評価
  const indices = new Array(6).fill(0);
  const maxIndices = slotOptions.map(opts => opts.length);

  let evaluationCount = 0;
  const maxEvaluations = EXHAUSTIVE_SEARCH_THRESHOLD;
  const YIELD_INTERVAL = 500; // 500回ごとにUIスレッド解放

  while (evaluationCount < maxEvaluations) {
    // 現在の組み合わせを構築
    const combination: Record<EquipSlot, CandidateEquipment | null> = {
      weapon: null, head: null, body: null, leg: null, accessory1: null, accessory2: null,
    };
    const configIndices: Record<EquipSlot, number> = {
      weapon: 0, head: 0, body: 0, leg: 0, accessory1: 0, accessory2: 0,
    };

    for (let i = 0; i < 6; i++) {
      const opt = slotOptions[i][indices[i]];
      combination[slots[i]] = opt.candidate;
      configIndices[slots[i]] = opt.configIndex;
    }

    // 評価
    const { score, stats, meetsMinimum } = evaluateCombination(combination, configIndices, context, eqConst);
    evaluationCount++;

    if (meetsMinimum && score > 0) {
      solutions.push({
        equipmentSet: { ...combination },
        configIndices: { ...configIndices },
        score,
        stats,
      });

      // 上位N件のみ保持（メモリ効率のため）
      if (solutions.length > maxResults * 2) {
        solutions.sort((a, b) => b.score - a.score);
        solutions.length = maxResults;
      }
    }

    // UIスレッド解放（定期的）
    if (evaluationCount % YIELD_INTERVAL === 0) {
      await new Promise(resolve => setTimeout(resolve, 0));
    }

    // 次の組み合わせへ
    let carry = true;
    for (let i = 5; i >= 0 && carry; i--) {
      indices[i]++;
      if (indices[i] >= maxIndices[i]) {
        indices[i] = 0;
      } else {
        carry = false;
      }
    }

    // 全組み合わせを評価し終わったら終了
    if (carry) break;
  }

  // スコア降順でソート
  solutions.sort((a, b) => b.score - a.score);

  console.log(`[exhaustiveSearchAsync] Evaluated ${evaluationCount} combinations, found ${solutions.length} valid solutions`);

  return solutions.slice(0, maxResults);
}

/**
 * 組み合わせ数を計算
 */
function calculateCombinationCount(pool: EquipmentPool): number {
  const slots: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];
  let count = 1;

  for (const slot of slots) {
    const candidates = pool[slot];
    if (candidates.length === 0) {
      // 空のスロットは1通り
      continue;
    }

    let slotCount = 0;
    for (const candidate of candidates) {
      slotCount += candidate.configurations.length;
    }
    count *= Math.max(slotCount, 1);
  }

  return count;
}

/**
 * 貪欲法で初期解を構築
 */
function greedyInitialSolution(
  pool: EquipmentPool,
  context: EvaluationContext,
  eqConst: any
): ScoredCombination {
  const slots: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];
  const combination: Record<EquipSlot, CandidateEquipment | null> = {
    weapon: null,
    head: null,
    body: null,
    leg: null,
    accessory1: null,
    accessory2: null,
  };
  const configIndices: Record<EquipSlot, number> = {
    weapon: 0,
    head: 0,
    body: 0,
    leg: 0,
    accessory1: 0,
    accessory2: 0,
  };

  // 各スロットで最高スコアの装備を選択
  for (const slot of slots) {
    const candidates = pool[slot];
    if (candidates.length === 0) continue;

    let bestCandidate: CandidateEquipment | null = null;
    let bestConfigIndex = 0;
    let bestScore = -Infinity;

    for (const candidate of candidates) {
      for (let configIdx = 0; configIdx < candidate.configurations.length; configIdx++) {
        // 一時的にこの装備を追加して評価
        const tempCombination = { ...combination, [slot]: candidate };
        const tempIndices = { ...configIndices, [slot]: configIdx };

        const { score } = evaluateCombination(tempCombination, tempIndices, context, eqConst);

        if (score > bestScore) {
          bestScore = score;
          bestCandidate = candidate;
          bestConfigIndex = configIdx;
        }
      }
    }

    if (bestCandidate) {
      combination[slot] = bestCandidate;
      configIndices[slot] = bestConfigIndex;
    }
  }

  const { score, stats } = evaluateCombination(combination, configIndices, context, eqConst);

  return {
    equipmentSet: combination,
    configIndices,
    score,
    stats,
  };
}

