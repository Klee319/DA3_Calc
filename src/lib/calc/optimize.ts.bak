// ===== Multi-Start Greedy（Phase 1） =====
/** スロット順序戦略 */
type SlotOrderStrategy = 'default' | 'reverse' | 'stat_priority';

/**
 * 異なるスロット順序で貪欲法を実行
 */
async function greedyWithSlotOrder(
  pool: EquipmentPool,
  context: EvaluationContext,
  eqConst: any,
  slotOrder: EquipSlot[],
  contextKey: string = ''
): Promise<ScoredCombination> {
  const combination: Record<EquipSlot, CandidateEquipment | null> = {
    weapon: null,
    head: null,
    body: null,
    leg: null,
    accessory1: null,
    accessory2: null,
  };
  const configIndices: Record<EquipSlot, number> = {
    weapon: 0,
    head: 0,
    body: 0,
    leg: 0,
    accessory1: 0,
    accessory2: 0,
  };

  let evalCount = 0;
  const YIELD_INTERVAL = 50;

  // 指定されたスロット順序で最高スコアの装備を選択
  for (const slot of slotOrder) {
    const candidates = pool[slot];
    if (candidates.length === 0) continue;

    let bestCandidate: CandidateEquipment | null = null;
    let bestConfigIndex = 0;
    let bestScore = -Infinity;

    for (const candidate of candidates) {
      for (let configIdx = 0; configIdx < candidate.configurations.length; configIdx++) {
        const tempCombination = { ...combination, [slot]: candidate };
        const tempIndices = { ...configIndices, [slot]: configIdx };

        const { score } = evaluateCombinationCached(tempCombination, tempIndices, context, eqConst, contextKey);
        evalCount++;

        if (score > bestScore) {
          bestScore = score;
          bestCandidate = candidate;
          bestConfigIndex = configIdx;
        }

        if (evalCount % YIELD_INTERVAL === 0) {
          await new Promise(resolve => setTimeout(resolve, 0));
        }
      }
    }

    if (bestCandidate) {
      combination[slot] = bestCandidate;
      configIndices[slot] = bestConfigIndex;
    }
  }

  const { score, stats } = evaluateCombinationCached(combination, configIndices, context, eqConst, contextKey);

  return {
    equipmentSet: combination,
    configIndices,
    score,
    stats,
  };
}

/**
 * 最低必須ステータス優先のグリーディ探索
 * minimumStatsが設定されている場合、そのステータスを達成するための装備を優先的に選択
 * スコア最大化よりも最低必須ステータスの達成を優先する
 */
async function greedyWithMinimumStatsPriority(
  pool: EquipmentPool,
  context: EvaluationContext,
  eqConst: any,
  slotOrder: EquipSlot[],
  contextKey: string = ''
): Promise<ScoredCombination> {
  const combination: Record<EquipSlot, CandidateEquipment | null> = {
    weapon: null,
    head: null,
    body: null,
    leg: null,
    accessory1: null,
    accessory2: null,
  };
  const configIndices: Record<EquipSlot, number> = {
    weapon: 0,
    head: 0,
    body: 0,
    leg: 0,
    accessory1: 0,
    accessory2: 0,
  };

  let evalCount = 0;
  const YIELD_INTERVAL = 50;

  // 最低必須ステータスが設定されているか確認
  const hasMinimumStats = context.minimumStats &&
    Object.values(context.minimumStats).some(v => v !== undefined && v > 0);

  // 指定されたスロット順序で装備を選択
  for (const slot of slotOrder) {
    const candidates = pool[slot];
    if (candidates.length === 0) continue;

    let bestCandidate: CandidateEquipment | null = null;
    let bestConfigIndex = 0;
    let bestCombinedScore = -Infinity;

    for (const candidate of candidates) {
      for (let configIdx = 0; configIdx < candidate.configurations.length; configIdx++) {
        const tempCombination = { ...combination, [slot]: candidate };
        const tempIndices = { ...configIndices, [slot]: configIdx };

        const { score, stats, meetsMinimum } = evaluateCombinationCached(tempCombination, tempIndices, context, eqConst, contextKey);
        evalCount++;

        // combinedScore: 最低必須ステータス達成度を加味したスコア
        let combinedScore: number;

        if (hasMinimumStats) {
          // 最低必須ステータスが設定されている場合
          const progress = calculateMinimumStatsProgress(stats, context.minimumStats);
          const deficit = calculateMinimumStatsDeficit(stats, context.minimumStats);

          if (meetsMinimum) {
            // 最低必須を満たしている場合: 高いベーススコア + ダメージスコア
            combinedScore = 1000000 + score;
          } else {
            // 最低必須を満たしていない場合: 達成度に基づくスコア + 少しのダメージボーナス
            // deficit が小さいほど良い（不足分が少ない）
            // progress が大きいほど良い（達成率が高い）
            combinedScore = progress * 500000 - deficit * 100 + score * 0.001;
          }
        } else {
          // 最低必須ステータスが設定されていない場合: 通常のスコアで評価
          combinedScore = score;
        }

        if (combinedScore > bestCombinedScore) {
          bestCombinedScore = combinedScore;
          bestCandidate = candidate;
          bestConfigIndex = configIdx;
        }

        if (evalCount % YIELD_INTERVAL === 0) {
          await new Promise(resolve => setTimeout(resolve, 0));
        }
      }
    }

    if (bestCandidate) {
      combination[slot] = bestCandidate;
      configIndices[slot] = bestConfigIndex;
    }
  }

  const { score, stats, meetsMinimum } = evaluateCombinationCached(combination, configIndices, context, eqConst, contextKey);

  return {
    equipmentSet: combination,
    configIndices,
    score: meetsMinimum ? score : 0, // 最終的に最低必須を満たしていない場合は0
    stats,
  };
}

/**
 * Multi-Start Greedy + Crossover（Phase 1）
 * 複数の初期点から探索を開始し、局所最適を回避
 */
async function multiStartGreedyAsync(
  pool: EquipmentPool,
  context: EvaluationContext,
  eqConst: any,
  contextKey: string = ''
): Promise<ScoredCombination[]> {
  const solutions: ScoredCombination[] = [];

  // 最低必須ステータスが設定されているか確認
  const hasMinimumStats = context.minimumStats &&
    Object.values(context.minimumStats).some(v => v !== undefined && v > 0);

  // Step 1: 異なる戦略で初期解を構築

  // 初期点1: デフォルト順序（weapon→head→body→leg→accessory1→accessory2）
  const defaultOrder: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];
  const solution1 = await greedyWithSlotOrder(pool, context, eqConst, defaultOrder, contextKey);
  solutions.push(solution1);
  console.log(`[MultiStart] Strategy 1 (default order): score=${solution1.score.toFixed(0)}`);

  // 初期点2: 逆順序（accessory2→accessory1→leg→body→head→weapon）
  const reverseOrder: EquipSlot[] = ['accessory2', 'accessory1', 'leg', 'body', 'head', 'weapon'];
  const solution2 = await greedyWithSlotOrder(pool, context, eqConst, reverseOrder, contextKey);
  solutions.push(solution2);
  console.log(`[MultiStart] Strategy 2 (reverse order): score=${solution2.score.toFixed(0)}`);

  // 初期点3: 最低必須ステータス優先探索（設定されている場合のみ）
  if (hasMinimumStats) {
    console.log('[MultiStart] Strategy 3 (minimum stats priority): enabled');

    // 防具スロットを先に選択（head→body→leg→weapon→accessory1→accessory2）
    const armorFirstOrder: EquipSlot[] = ['head', 'body', 'leg', 'weapon', 'accessory1', 'accessory2'];
    const solution3 = await greedyWithMinimumStatsPriority(pool, context, eqConst, armorFirstOrder, contextKey);
    if (solution3.score > 0) {
      solutions.push(solution3);
      console.log(`[MultiStart] Strategy 3a (armor first, minimum priority): score=${solution3.score.toFixed(0)}`);
    }

    // 逆順（accessory→leg→body→head→weapon）でも試す
    const reverseArmorOrder: EquipSlot[] = ['accessory1', 'accessory2', 'leg', 'body', 'head', 'weapon'];
    const solution4 = await greedyWithMinimumStatsPriority(pool, context, eqConst, reverseArmorOrder, contextKey);
    if (solution4.score > 0) {
      solutions.push(solution4);
      console.log(`[MultiStart] Strategy 3b (reverse armor, minimum priority): score=${solution4.score.toFixed(0)}`);
    }

    // デフォルト順序でも最低必須優先探索
    const solution5 = await greedyWithMinimumStatsPriority(pool, context, eqConst, defaultOrder, contextKey);
    if (solution5.score > 0) {
      solutions.push(solution5);
      console.log(`[MultiStart] Strategy 3c (default order, minimum priority): score=${solution5.score.toFixed(0)}`);
    }
  }

  // Step 2: Crossover（いいとこどり）
  // 2つの解の各スロットを組み合わせて新しい解を生成
  const crossoverSolutions = await generateCrossoverSolutions(
    [solution1, solution2],
    context,
    eqConst,
    contextKey
  );
  solutions.push(...crossoverSolutions);

  // スコア順でソート
  solutions.sort((a, b) => b.score - a.score);

  console.log(`[MultiStart] Total candidates: ${solutions.length}, best score: ${solutions[0]?.score.toFixed(0) || 0}`);

  return solutions;
}

/**
 * Crossover: 2つの解から各スロットを組み合わせた新しい解を生成
 */
async function generateCrossoverSolutions(
  parents: ScoredCombination[],
  context: EvaluationContext,
  eqConst: any,
  contextKey: string
): Promise<ScoredCombination[]> {
  if (parents.length < 2) return [];

  const [parent1, parent2] = parents;
  const slots: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];
  const crossovers: ScoredCombination[] = [];

  // Crossoverパターン: 武器スロットを固定し、防具/アクセサリーを混合
  // パターン1: parent1の武器・頭・胴 + parent2の脚・アクセ
  const crossover1Combination: Record<EquipSlot, CandidateEquipment | null> = {
    weapon: parent1.equipmentSet.weapon,
    head: parent1.equipmentSet.head,
    body: parent1.equipmentSet.body,
    leg: parent2.equipmentSet.leg,
    accessory1: parent2.equipmentSet.accessory1,
    accessory2: parent2.equipmentSet.accessory2,
  };
  const crossover1Indices: Record<EquipSlot, number> = {
    weapon: parent1.configIndices.weapon,
    head: parent1.configIndices.head,
    body: parent1.configIndices.body,
    leg: parent2.configIndices.leg,
    accessory1: parent2.configIndices.accessory1,
    accessory2: parent2.configIndices.accessory2,
  };
  const result1 = evaluateCombinationCached(crossover1Combination, crossover1Indices, context, eqConst, contextKey);
  if (result1.meetsMinimum && result1.score > 0) {
    crossovers.push({
      equipmentSet: crossover1Combination,
      configIndices: crossover1Indices,
      score: result1.score,
      stats: result1.stats,
    });
  }

  // パターン2: parent2の武器・頭・胴 + parent1の脚・アクセ
  const crossover2Combination: Record<EquipSlot, CandidateEquipment | null> = {
    weapon: parent2.equipmentSet.weapon,
    head: parent2.equipmentSet.head,
    body: parent2.equipmentSet.body,
    leg: parent1.equipmentSet.leg,
    accessory1: parent1.equipmentSet.accessory1,
    accessory2: parent1.equipmentSet.accessory2,
  };
  const crossover2Indices: Record<EquipSlot, number> = {
    weapon: parent2.configIndices.weapon,
    head: parent2.configIndices.head,
    body: parent2.configIndices.body,
    leg: parent1.configIndices.leg,
    accessory1: parent1.configIndices.accessory1,
    accessory2: parent1.configIndices.accessory2,
  };
  const result2 = evaluateCombinationCached(crossover2Combination, crossover2Indices, context, eqConst, contextKey);
  if (result2.meetsMinimum && result2.score > 0) {
    crossovers.push({
      equipmentSet: crossover2Combination,
      configIndices: crossover2Indices,
      score: result2.score,
      stats: result2.stats,
    });
  }

  // パターン3: 武器parent1 + 防具parent2 + アクセparent1
  const crossover3Combination: Record<EquipSlot, CandidateEquipment | null> = {
    weapon: parent1.equipmentSet.weapon,
    head: parent2.equipmentSet.head,
    body: parent2.equipmentSet.body,
    leg: parent2.equipmentSet.leg,
    accessory1: parent1.equipmentSet.accessory1,
    accessory2: parent1.equipmentSet.accessory2,
  };
  const crossover3Indices: Record<EquipSlot, number> = {
    weapon: parent1.configIndices.weapon,
    head: parent2.configIndices.head,
    body: parent2.configIndices.body,
    leg: parent2.configIndices.leg,
    accessory1: parent1.configIndices.accessory1,
    accessory2: parent1.configIndices.accessory2,
  };
  const result3 = evaluateCombinationCached(crossover3Combination, crossover3Indices, context, eqConst, contextKey);
  if (result3.meetsMinimum && result3.score > 0) {
    crossovers.push({
      equipmentSet: crossover3Combination,
      configIndices: crossover3Indices,
      score: result3.score,
      stats: result3.stats,
    });
  }

  return crossovers;
}

/**
 * ローカルサーチで解を改善（1-opt + 2-opt）同期版
 */
function localSearch(
  initial: ScoredCombination,
  pool: EquipmentPool,
  context: EvaluationContext,
  eqConst: any,
  maxIterations: number = 100
): ScoredCombination {
  let current = { ...initial };
  const slots: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];

  for (let iter = 0; iter < maxIterations; iter++) {
    let improved = false;

    // 1-opt: 各スロットで近傍探索
    for (const slot of slots) {
      const candidates = pool[slot];
      if (candidates.length === 0) continue;

      for (const candidate of candidates) {
        for (let configIdx = 0; configIdx < candidate.configurations.length; configIdx++) {
          // 現在と同じ場合はスキップ
          if (
            current.equipmentSet[slot]?.id === candidate.id &&
            current.configIndices[slot] === configIdx
          ) {
            continue;
          }

          // 一時的に変更して評価
          const tempCombination = { ...current.equipmentSet, [slot]: candidate };
          const tempIndices = { ...current.configIndices, [slot]: configIdx };

          const { score, stats } = evaluateCombination(tempCombination, tempIndices, context, eqConst);

          if (score > current.score) {
            current = {
              equipmentSet: tempCombination,
              configIndices: tempIndices,
              score,
              stats,
            };
            improved = true;
          }
        }
      }
    }

    // 2-opt: 2スロット同時変更
    if (!improved) {
      for (let i = 0; i < slots.length && !improved; i++) {
        for (let j = i + 1; j < slots.length && !improved; j++) {
          const slot1 = slots[i];
          const slot2 = slots[j];
          const candidates1 = pool[slot1];
          const candidates2 = pool[slot2];

          if (candidates1.length === 0 || candidates2.length === 0) continue;

          // サンプリング（計算量削減）：各スロット上位10件のみ
          const sampled1 = candidates1.slice(0, 10);
          const sampled2 = candidates2.slice(0, 10);

          for (const cand1 of sampled1) {
            for (let cfg1 = 0; cfg1 < cand1.configurations.length; cfg1++) {
              for (const cand2 of sampled2) {
                for (let cfg2 = 0; cfg2 < cand2.configurations.length; cfg2++) {
                  // 両方とも現在と同じならスキップ
                  if (
                    current.equipmentSet[slot1]?.id === cand1.id &&
                    current.configIndices[slot1] === cfg1 &&
                    current.equipmentSet[slot2]?.id === cand2.id &&
                    current.configIndices[slot2] === cfg2
                  ) {
                    continue;
                  }

                  const tempCombination = {
                    ...current.equipmentSet,
                    [slot1]: cand1,
                    [slot2]: cand2,
                  };
                  const tempIndices = {
                    ...current.configIndices,
                    [slot1]: cfg1,
                    [slot2]: cfg2,
                  };

                  const { score, stats } = evaluateCombination(tempCombination, tempIndices, context, eqConst);

                  if (score > current.score) {
                    current = {
                      equipmentSet: tempCombination,
                      configIndices: tempIndices,
                      score,
                      stats,
                    };
                    improved = true;
                  }
                }
              }
            }
          }
        }
      }
    }

    // 改善がなければ終了
    if (!improved) break;
  }

  return current;
}

/**
 * ローカルサーチで解を改善（非同期版 - UIスレッド解放あり）
 * Phase 3: Adaptive Local Search - 停滞時のみ限定的2-optを発動
 */
async function localSearchAsync(
  initial: ScoredCombination,
  pool: EquipmentPool,
  context: EvaluationContext,
  eqConst: any,
  maxIterations: number = 50, // イテレーション数を削減
  contextKey: string = ''
): Promise<ScoredCombination> {
  let current = { ...initial };
  const slots: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];
  let evalCount = 0;
  const YIELD_INTERVAL = 100;
  let stagnationCount = 0;  // 連続停滞回数
  const STAGNATION_THRESHOLD = 3;  // 3回連続改善なしで2-optを発動

  for (let iter = 0; iter < maxIterations; iter++) {
    let improved = false;

    // 1-opt: 各スロットで近傍探索
    for (const slot of slots) {
      const candidates = pool[slot];
      if (candidates.length === 0) continue;

      for (const candidate of candidates) {
        for (let configIdx = 0; configIdx < candidate.configurations.length; configIdx++) {
          if (
            current.equipmentSet[slot]?.id === candidate.id &&
            current.configIndices[slot] === configIdx
          ) {
            continue;
          }

          const tempCombination = { ...current.equipmentSet, [slot]: candidate };
          const tempIndices = { ...current.configIndices, [slot]: configIdx };
          const { score, stats } = evaluateCombinationCached(tempCombination, tempIndices, context, eqConst, contextKey);
          evalCount++;

          if (evalCount % YIELD_INTERVAL === 0) {
            await new Promise(resolve => setTimeout(resolve, 0));
          }

          if (score > current.score) {
            current = { equipmentSet: tempCombination, configIndices: tempIndices, score, stats };
            improved = true;
          }
        }
      }
    }

    if (improved) {
      stagnationCount = 0;  // 改善があれば停滞カウントをリセット
    } else {
      stagnationCount++;

      // Phase 3: Adaptive 2-opt - 停滞時のみ依存ステータスに基づく2-optを発動
      if (stagnationCount >= STAGNATION_THRESHOLD) {
        const twoOptResult = await adaptiveTwoOptAsync(current, pool, context, eqConst, contextKey);
        if (twoOptResult.score > current.score) {
          current = twoOptResult;
          improved = true;
          stagnationCount = 0;
          console.log(`[AdaptiveLocalSearch] 2-opt improved: ${twoOptResult.score.toFixed(0)}`);
        } else {
          // 2-optでも改善なし → 終了
          break;
        }
      }
    }

    if (!improved && stagnationCount < STAGNATION_THRESHOLD) break;
  }

  return current;
}

/**
 * Adaptive 2-opt: 依存ステータスに基づいて2スロット同時変更
 * statCoefficientsから上位2ステータスを取得し、そのEXを持つスロット同士で2-optを実行
 */
async function adaptiveTwoOptAsync(
  current: ScoredCombination,
  pool: EquipmentPool,
  context: EvaluationContext,
  eqConst: any,
  contextKey: string
): Promise<ScoredCombination> {
  let best = { ...current };
  const evalCount = { count: 0 };
  const YIELD_INTERVAL = 50;

  // relevantStatsから依存ステータスを取得
  const coeffs = context.relevantStats?.statCoefficients || {};
  const sortedStats = Object.entries(coeffs)
    .filter(([_, v]) => v > 0)
    .sort((a, b) => b[1] - a[1])
    .map(([k, _]) => k);

  // 上位2ステータスのEXを持つスロットを特定
  // 防具・アクセサリーのみが対象（武器はEXを持たない）
  const armorSlots: EquipSlot[] = ['head', 'body', 'leg', 'accessory1', 'accessory2'];
  const relevantSlots: EquipSlot[] = [];

  // 現在の装備のEXタイプをチェック
  for (const slot of armorSlots) {
    const candidate = current.equipmentSet[slot];
    if (!candidate) continue;

    const configIdx = current.configIndices[slot] || 0;
    const config = candidate.configurations[configIdx];
    const ex1 = config?.exStats?.ex1;
    const ex2 = config?.exStats?.ex2;

    // 上位2ステータスに関連するEXを持つスロットを追加
    // Speed → Agility にマッピング
    const normalizedStats = sortedStats.slice(0, 2).map(s => s === 'Agility' ? 'Speed' : s);
    if (ex1 && normalizedStats.includes(ex1)) {
      relevantSlots.push(slot);
    } else if (ex2 && normalizedStats.includes(ex2)) {
      relevantSlots.push(slot);
    }
  }

  // 関連スロットがない場合は全防具スロットを対象
  const targetSlots = relevantSlots.length >= 2 ? relevantSlots : armorSlots;

  // 2-optペアを生成（最大2ペア）
  const pairs: [EquipSlot, EquipSlot][] = [];
  for (let i = 0; i < targetSlots.length && pairs.length < 2; i++) {
    for (let j = i + 1; j < targetSlots.length && pairs.length < 2; j++) {
      pairs.push([targetSlots[i], targetSlots[j]]);
    }
  }

  // 各ペアで2-optを実行
  for (const [slot1, slot2] of pairs) {
    const candidates1 = pool[slot1];
    const candidates2 = pool[slot2];

    if (candidates1.length === 0 || candidates2.length === 0) continue;

    // サンプリング（上位10件のみ）
    const sampled1 = candidates1.slice(0, 10);
    const sampled2 = candidates2.slice(0, 10);

    for (const cand1 of sampled1) {
      for (let cfg1 = 0; cfg1 < Math.min(cand1.configurations.length, 3); cfg1++) {
        for (const cand2 of sampled2) {
          for (let cfg2 = 0; cfg2 < Math.min(cand2.configurations.length, 3); cfg2++) {
            // 現在と同じならスキップ
            if (
              best.equipmentSet[slot1]?.id === cand1.id &&
              best.configIndices[slot1] === cfg1 &&
              best.equipmentSet[slot2]?.id === cand2.id &&
              best.configIndices[slot2] === cfg2
            ) {
              continue;
            }

            const tempCombination = {
              ...best.equipmentSet,
              [slot1]: cand1,
              [slot2]: cand2,
            };
            const tempIndices = {
              ...best.configIndices,
              [slot1]: cfg1,
              [slot2]: cfg2,
            };

            const { score, stats } = evaluateCombinationCached(tempCombination, tempIndices, context, eqConst, contextKey);
            evalCount.count++;

            if (evalCount.count % YIELD_INTERVAL === 0) {
              await new Promise(resolve => setTimeout(resolve, 0));
            }

            if (score > best.score) {
              best = {
                equipmentSet: tempCombination,
                configIndices: tempIndices,
                score,
                stats,
              };
            }
          }
        }
      }
    }
  }

  return best;
}

/**
 * 多様な解を生成（非同期版）
 */
async function generateDiverseSolutionsAsync(
  pool: EquipmentPool,
  context: EvaluationContext,
  eqConst: any,
  maxResults: number = 10
): Promise<ScoredCombination[]> {
  const solutions: ScoredCombination[] = [];
  const usedWeapons = new Set<string>();
  let count = 0;

  // 各武器で最適化を試行（上位5件のみに制限）
  const weaponsToTry = pool.weapon.slice(0, 5);
  for (const weaponCandidate of weaponsToTry) {
    if (solutions.length >= maxResults) break;
    if (usedWeapons.has(weaponCandidate.name)) continue;

    // 武器を固定して貪欲法
    const fixedPool = {
      ...pool,
      weapon: [weaponCandidate],
    };

    const initial = greedyInitialSolution(fixedPool, context, eqConst);
    const improved = await localSearchAsync(initial, fixedPool, context, eqConst);

    // 重複チェック
    const isDuplicate = solutions.some(
      (s) => Math.abs(s.score - improved.score) < 0.001
    );

    if (!isDuplicate) {
      solutions.push(improved);
      usedWeapons.add(weaponCandidate.name);
    }

    count++;
    // UIスレッド解放
    if (count % 2 === 0) {
      await new Promise(resolve => setTimeout(resolve, 0));
    }
  }

  // スコア降順でソート
  solutions.sort((a, b) => b.score - a.score);

  return solutions.slice(0, maxResults);
}

// ===== ルーンストーン探索 =====

/** ルーンストーン組み合わせ型 */
interface RunestoneCombination {
  runestones: RunestoneData[];
  totalBonus: Record<string, number>;
}

/**
 * 紋章のPareto支配フィルタリング
 * 依存ステータスのみで比較し、全てで劣る（または等しい）紋章を除外
 * @param emblems 紋章リスト
 * @param relevantStats 依存ステータス（指定がない場合は全ステータスで比較）
 */
function filterDominatedEmblems(
  emblems: EmblemData[],
  relevantStats?: RelevantStats
): EmblemData[] {
  if (!emblems || emblems.length <= 1) {
    return emblems;
  }

  // InternalStatKey -> 紋章CSVキーのマッピング
  const statKeyMapping: Record<string, string> = {
    'Power': '力（%不要）',
    'Magic': '魔力（%不要）',
    'HP': '体力（%不要）',
    'Mind': '精神（%不要）',
    'Agility': '素早さ（%不要）',
    'Dex': '器用（%不要）',
    'CritDamage': '撃力（%不要）',
    'Defense': '守備力（%不要）',
  };

  // 依存ステータスに基づいて比較対象キーを決定
  let compareKeys: string[];
  if (relevantStats && relevantStats.directStats.size > 0) {
    compareKeys = [];
    const directStatsArray = Array.from(relevantStats.directStats);
    for (const internalKey of directStatsArray) {
      const csvKey = statKeyMapping[internalKey];
      if (csvKey) {
        compareKeys.push(csvKey);
      }
    }
    // 撃力は常に重要（ダメージ計算に影響）なので追加
    if (!compareKeys.includes('撃力（%不要）')) {
      compareKeys.push('撃力（%不要）');
    }
  } else {
    // relevantStatsがない場合は全ステータスで比較
    compareKeys = Object.values(statKeyMapping);
  }

  console.log(`[Optimize] Emblem filter using stats: ${compareKeys.join(', ')}`);

  const getStatValue = (emblem: EmblemData, key: string): number => {
    const value = (emblem as unknown as Record<string, unknown>)[key];
    return typeof value === 'number' ? value : 0;
  };

  // Pareto支配チェック: AがBに支配されているか（依存ステータスのみで比較）
  const isDominated = (a: EmblemData, b: EmblemData): boolean => {
    let allLessOrEqual = true;
    let anyStrictlyLess = false;

    for (const key of compareKeys) {
      const aVal = getStatValue(a, key);
      const bVal = getStatValue(b, key);
      if (aVal > bVal) {
        allLessOrEqual = false;
        break;
      }
      if (aVal < bVal) {
        anyStrictlyLess = true;
      }
    }

    return allLessOrEqual && anyStrictlyLess;
  };

  // 支配されていない紋章のみを残す
  const result: EmblemData[] = [];
  for (let i = 0; i < emblems.length; i++) {
    let dominated = false;
    for (let j = 0; j < emblems.length; j++) {
      if (i !== j && isDominated(emblems[i], emblems[j])) {
        dominated = true;
        break;
      }
    }
    if (!dominated) {
      result.push(emblems[i]);
    }
  }

  console.log(`[Optimize] Emblem Pareto filter: ${emblems.length} -> ${result.length} (pruned ${emblems.length - result.length})`);
  return result;
}

/**
 * ルーンストーン組み合わせを生成
 * グレード制約: 各グレードから最大1個まで装備可能（計最大4個）
 */
function buildRunestoneCombinations(
  runestones: RunestoneData[],
  relevantStats?: RelevantStats
): RunestoneCombination[] {
  if (!runestones || runestones.length === 0) {
    return [{ runestones: [], totalBonus: {} }];
  }

  // グレード別にグループ化
  const grades = ['ノーマル', 'グレート', 'バスター', 'レプリカ'] as const;
  const byGrade: Map<string, RunestoneData[]> = new Map();
  for (const grade of grades) {
    byGrade.set(grade, []);
  }
  for (const rune of runestones) {
    const gradeList = byGrade.get(rune.グレード);
    if (gradeList) {
      gradeList.push(rune);
    }
  }

  // 各グレードから「なし」または「1個」を選択する組み合わせを生成
  // 4グレード × 各N種 = 最大 (N+1)^4 組み合わせ
  const combinations: RunestoneCombination[] = [];

  // 各グレードの選択肢を配列化（nullは「選択なし」）
  const gradeOptions: (RunestoneData | null)[][] = grades.map(grade => {
    const runesInGrade = byGrade.get(grade) || [];
    return [null, ...runesInGrade]; // nullは「このグレードでは選択しない」
  });

  // 全組み合わせを探索
  const generateCombinations = (
    gradeIndex: number,
    currentRunes: RunestoneData[]
  ): void => {
    if (gradeIndex >= gradeOptions.length) {
      // 組み合わせ完成
      const totalBonus = calculateRunestoneBonus(currentRunes);
      combinations.push({
        runestones: [...currentRunes],
        totalBonus,
      });
      return;
    }

    for (const option of gradeOptions[gradeIndex]) {
      if (option === null) {
        // このグレードでは選択しない
        generateCombinations(gradeIndex + 1, currentRunes);
      } else {
        // このルーンストーンを選択
        generateCombinations(gradeIndex + 1, [...currentRunes, option]);
      }
    }
  };

  generateCombinations(0, []);

  // relevantStatsがある場合、Pareto支配による枝刈りを実行
  if (relevantStats) {
    // 依存ステータスに基づく比較対象キーを決定
    const compareKeys: string[] = [];
    const directStatsArray = Array.from(relevantStats.directStats);
    const statKeyMapping: Record<string, string> = {
      'Power': '力',
      'Magic': '魔力',
      'HP': '体力',
      'Mind': '精神',
      'Agility': '素早さ',
      'Dex': '器用',
      'CritDamage': '撃力',
      'Defense': '守備力',
    };

    for (const internalKey of directStatsArray) {
      const csvKey = statKeyMapping[internalKey];
      if (csvKey) {
        compareKeys.push(csvKey);
      }
    }
    // 撃力は常に重要（ダメージ計算に影響）
    if (!compareKeys.includes('撃力')) {
      compareKeys.push('撃力');
    }

    console.log(`[Optimize] Runestone filter using stats: ${compareKeys.join(', ')}`);

    const getStatValue = (comb: RunestoneCombination, key: string): number => {
      return (comb.totalBonus as Record<string, number>)[key] || 0;
    };

    // Pareto支配チェック: AがBに支配されているか（依存ステータスのみで比較）
    const isDominated = (a: RunestoneCombination, b: RunestoneCombination): boolean => {
      let dominated = true;
      let strictlyWorse = false;

      for (const key of compareKeys) {
        const aVal = getStatValue(a, key);
        const bVal = getStatValue(b, key);
        if (aVal > bVal) {
          dominated = false;
          break;
        }
        if (aVal < bVal) {
          strictlyWorse = true;
        }
      }

      return dominated && strictlyWorse;
    };

    // Pareto支配されていない組み合わせのみを残す
    const nonDominated: RunestoneCombination[] = [];
    for (const comb of combinations) {
      let dominated = false;
      for (const other of combinations) {
        if (comb !== other && isDominated(comb, other)) {
          dominated = true;
          break;
        }
      }
      if (!dominated) {
        nonDominated.push(comb);
      }
    }

    console.log(`[Optimize] Runestone Pareto filter: ${combinations.length} -> ${nonDominated.length} (pruned ${combinations.length - nonDominated.length})`);
    return nonDominated;
  }

  console.log(`[Optimize] Runestone combinations: ${combinations.length}`);
  return combinations;
}

/**
 * ルーンストーンのステータスボーナスを計算
 */
function calculateRunestoneBonus(runestones: RunestoneData[]): Record<string, number> {
  const bonus: Record<string, number> = {};

  for (const rune of runestones) {
    if (rune.力) bonus['力'] = (bonus['力'] || 0) + rune.力;
    if (rune.魔力) bonus['魔力'] = (bonus['魔力'] || 0) + rune.魔力;
    if (rune.体力) bonus['体力'] = (bonus['体力'] || 0) + rune.体力;
    if (rune.精神) bonus['精神'] = (bonus['精神'] || 0) + rune.精神;
    if (rune.素早さ) bonus['素早さ'] = (bonus['素早さ'] || 0) + rune.素早さ;
    if (rune.器用) bonus['器用'] = (bonus['器用'] || 0) + rune.器用;
    if (rune.撃力) bonus['撃力'] = (bonus['撃力'] || 0) + rune.撃力;
    if (rune.守備力) bonus['守備力'] = (bonus['守備力'] || 0) + rune.守備力;
  }

  return bonus;
}

// ===== メインエントリーポイント =====

/** 最適化オプション */
export interface OptimizeOptions {
  mode: OptimizeMode;
  targetStat?: InternalStatKey;
  skillMultiplier?: number;
  skillHits?: number;
  skillCoolTime?: number;
  availableWeaponTypes?: string[];
  availableArmorTypes?: string[];
  selectedWeaponType?: string | null;  // 評価用の選択武器種（複数武器種職業用）
  // 新しい制約条件
  minimumStats?: MinimumStatRequirements;
  jobGrade?: string;
  jobMaxLevel?: number;
  jobName?: string;  // 職業名（YAML形式）
  jobNameJP?: string;  // 職業名（日本語、SPデータ検索用）
  spAllocation?: Record<string, number>;  // SP振り分け（ユーザー必須分）
  runestoneBonus?: StatBlock;  // ルーンストーンボーナス（固定値）
  // バフ設定
  buffSettings?: {
    enabledBuffIds: string[];  // 有効なバフID
    skillLevel: number;        // スキルレベル
  };
  unlockedSkills?: string[];   // 解放済みスキル（バフ判定用）
  // ルーンストーン探索オプション
  enableRunestoneSearch?: boolean;  // ルーンストーン探索を有効化
}

/** 探索統計 */
export interface SearchStats {
  totalCandidates: number;
  evaluatedCombinations: number;
  prunedCombinations: number;
  elapsedTime: number;
  phase: string;
}

/** 最適化結果（統計付き） */
export interface OptimizeResultWithStats {
  results: OptimizeResult[];
  searchStats: SearchStats;
  warnings?: string[];  // 警告メッセージ
}

/**
 * 装備の最適化を実行
 */
export async function optimizeEquipment(
  currentBuild: CharacterBuild,
  targetSlots: EquipSlot[],
  constraints: OptimizeConstraints,
  skillForEvaluation: string,
  enemyParams: EnemyParams,
  gameData: OptimizeGameData,
  onProgress?: (progress: OptimizeProgress) => void,
  options?: OptimizeOptions
): Promise<OptimizeResultWithStats> {
  const startTime = Date.now();

  // 探索統計を追跡
  let evaluatedCombinations = 0;

  // 中間結果用：現在の最良解を追跡
  let currentBestSolution: (ScoredCombination & { usedEmblem?: EmblemData | null }) | null = null;
  let lastIntermediateReportTime = Date.now();
  const INTERMEDIATE_REPORT_INTERVAL = 30000; // 30秒

  // 進捗報告（拡張版：中間結果を含む）
  const reportProgress = (
    phase: string,
    current: number,
    total: number,
    message: string,
    bestScore?: number,
    bestSolution?: (ScoredCombination & { usedEmblem?: EmblemData | null }) | null
  ) => {
    if (onProgress) {
      const elapsedTime = Date.now() - startTime;
      const now = Date.now();

      // 中間結果の装備情報を生成
      let intermediateEquipment: { weapon?: string; head?: string; body?: string; leg?: string; accessory1?: string; accessory2?: string; emblem?: string } | undefined;
      let intermediateStats: { Power?: number; Magic?: number; HP?: number; Agility?: number; CritDamage?: number } | undefined;

      // 30秒ごと、または明示的に指定された場合に中間結果を報告
      const solutionToReport = bestSolution || currentBestSolution;
      if (solutionToReport && (now - lastIntermediateReportTime >= INTERMEDIATE_REPORT_INTERVAL || bestSolution)) {
        lastIntermediateReportTime = now;

        // 装備名を抽出
        intermediateEquipment = {};
        for (const slot of ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'] as const) {
          const eq = solutionToReport.equipmentSet[slot];
          if (eq) {
            intermediateEquipment[slot] = eq.name;
          }
        }
        if (solutionToReport.usedEmblem) {
          intermediateEquipment.emblem = solutionToReport.usedEmblem['アイテム名'] || solutionToReport.usedEmblem.name;
        }

        // ステータスを抽出
        if (solutionToReport.stats) {
          intermediateStats = {
            Power: Math.round(solutionToReport.stats.Power || 0),
            Magic: Math.round(solutionToReport.stats.Magic || 0),
            HP: Math.round(solutionToReport.stats.HP || 0),
            Agility: Math.round(solutionToReport.stats.Agility || 0),
            CritDamage: Math.round(solutionToReport.stats.CritDamage || 0),
          };
        }
      }

      onProgress({
        phase: phase as any,
        current,
        total,
        percentage: total > 0 ? Math.round((current / total) * 100) : 0,
        currentBest: bestScore ?? (currentBestSolution?.score || 0),
        message,
        elapsedTime,
        intermediateEquipment,
        intermediateStats,
      });
    }
  };

  // 最適化開始時に動的ステータスをクリア
  clearCurrentOptimizationStats();

  // 評価キャッシュをクリア（新しい最適化セッション開始）
  clearEvaluationCache();
  console.log('[Optimize] Evaluation cache cleared for new session');

  reportProgress('initializing', 0, 100, '初期化中...');

  // 使用可能な武器・防具タイプを取得
  const availableWeaponTypes: string[] = options?.availableWeaponTypes || [];
  const availableArmorTypes: string[] = options?.availableArmorTypes || [];

  console.log('[Optimize] availableWeaponTypes:', availableWeaponTypes);
  console.log('[Optimize] availableArmorTypes:', availableArmorTypes);
  console.log('[Optimize] constraints:', constraints);
  console.log('[Optimize] gameData weapons count:', gameData.weapons?.length);

  // スキル依存ステータスを分析（EX選択・叩き配分用）
  // V2を優先使用（武器種が指定されている場合）
  // ※buildEquipmentPoolより前に実行する必要がある
  let relevantStats: RelevantStats;
  // 選択武器種が指定されていればそれを使用、なければavailableWeaponTypesの先頭
  const primaryWeaponType = options?.selectedWeaponType || (availableWeaponTypes.length > 0 ? availableWeaponTypes[0] : 'Sword');

  // V2を使用して動的重みを計算（より正確な感度分析）
  if (availableWeaponTypes.length > 0) {
    // V2パラメータを構築
    const v2Params: Partial<WeightCalculationParams> = {
      currentStats: DEFAULT_STATS,
      weaponAttackPower: DEFAULT_WEAPON_PARAMS.weaponAttackPower,
      weaponCritDamage: DEFAULT_WEAPON_PARAMS.weaponCritDamage,
      critRate: DEFAULT_WEAPON_PARAMS.critRate,
      jobName: options?.jobName,
    };

    // V2で解析（内部でスキルID正規化を行う）
    relevantStats = analyzeSkillDependenciesV2(skillForEvaluation, primaryWeaponType, v2Params);

    // V2の重み情報もログ出力
    const weights = getWeightsForSkill(normalizeSkillId(skillForEvaluation), primaryWeaponType, {
      currentStats: DEFAULT_STATS,
      weaponAttackPower: DEFAULT_WEAPON_PARAMS.weaponAttackPower,
      weaponCritDamage: DEFAULT_WEAPON_PARAMS.weaponCritDamage,
      critRate: DEFAULT_WEAPON_PARAMS.critRate,
      jobName: options?.jobName,
    });
    console.log('[Optimize] V2 weights:', formatWeightsV2(weights));
  } else {
    // フォールバック: 従来の分析
    relevantStats = analyzeSkillDependencies(
      skillForEvaluation,
      gameData.skillCalc,
      gameData.weaponCalc,
      options?.jobName
    );
  }
  console.log('[Optimize] Skill dependencies analyzed:', formatRelevantStats(relevantStats));

  reportProgress('building_pool', 10, 100, '装備候補を構築中...');

  // 選択武器種（複数武器種職業用）
  const selectedWeaponType = options?.selectedWeaponType ?? null;

  // 装備プールを構築（relevantStatsとminimumStatsを渡してEX・叩き配分を最適化）
  const pool = buildEquipmentPool(gameData, constraints, availableWeaponTypes, availableArmorTypes, selectedWeaponType, relevantStats, options?.minimumStats);

  console.log('[Optimize] Pool sizes:', {
    weapon: pool.weapon.length,
    head: pool.head.length,
    body: pool.body.length,
    leg: pool.leg.length,
    accessory1: pool.accessory1.length,
    accessory2: pool.accessory2.length,
  });

  const totalCandidates =
    pool.weapon.length +
    pool.head.length +
    pool.body.length +
    pool.leg.length +
    pool.accessory1.length +
    pool.accessory2.length;

  reportProgress('building_pool', 30, 100, `装備候補: ${totalCandidates}件`);

  // 紋章データを取得（常に自動選択）
  const emblems = gameData.emblems || [];
  console.log('[Optimize] Emblem auto-selection enabled, candidates:', emblems.length);

  // 職業SPデータを取得（日本語名で検索）
  const jobNameForSPLookup = options?.jobNameJP || options?.jobName;
  const jobSPData = jobNameForSPLookup && gameData.jobSPData
    ? gameData.jobSPData.get(jobNameForSPLookup) || []
    : [];
  console.log('[Optimize] jobSPData lookup:', jobNameForSPLookup, 'found:', jobSPData.length, 'entries');

  // ※relevantStatsは前方で既に取得済み（buildEquipmentPoolで使用）

  // スキル名を正規化（damageCalculatorでのスキル検索用）
  const normalizedSkillId = normalizeSkillId(skillForEvaluation);
  console.log('[Optimize] Normalized skill ID:', normalizedSkillId, '(from:', skillForEvaluation, ')');

  // 評価コンテキストを設定
  const context: EvaluationContext = {
    mode: options?.mode || 'damage',
    targetStat: options?.targetStat,
    skillId: normalizedSkillId,           // スキルID（正規化済み）
    skillMultiplier: options?.skillMultiplier || 1.0,
    hits: options?.skillHits || 1,
    coolTime: options?.skillCoolTime || 5,
    enemyDefense: enemyParams.defense,
    enemyTypeResistance: enemyParams.typeResistance,
    enemyAttributeResistance: enemyParams.attributeResistance,
    // 新しいコンテキストフィールド
    jobMaxLevel: options?.jobMaxLevel || 100,
    jobName: options?.jobName,
    jobConst: gameData.jobConst,
    jobSPData,
    emblem: null,  // 紋章は探索ループ内で設定
    minimumStats: options?.minimumStats,
    // ダメージ計算用
    weaponCalc: gameData.weaponCalc,
    skillCalc: gameData.skillCalc,
    // スキル依存ステータス（EX選択用）
    relevantStats,
    // SP振り分けとルーンストーン
    spAllocation: options?.spAllocation,
    runestoneBonus: options?.runestoneBonus,
  };

  reportProgress('greedy', 40, 100, '初期解を構築中...');

  // 組み合わせ数を計算して探索戦略を決定
  const combinationCount = calculateCombinationCount(pool);
  // 紋章探索がある場合は全探索を無効化（計算量爆発を防ぐ）
  const hasEmblemSearch = emblems.length > 1;
  const useExhaustiveSearch = combinationCount <= EXHAUSTIVE_SEARCH_THRESHOLD && !hasEmblemSearch;
  console.log(`[Optimize] Combination count: ${combinationCount}, Use exhaustive search: ${useExhaustiveSearch}, hasEmblemSearch: ${hasEmblemSearch}`);

  // 紋章探索とルーンストーン探索を効率的に行う
  // 解決策に紋章・ルーンストーン情報も追跡
  let allSolutions: (ScoredCombination & {
    usedEmblem?: EmblemData | null;
    usedRunestones?: RunestoneCombination;
  })[] = [];

  // メモリ節約: 解リストが大きくなりすぎたら上位のみ保持
  const trimSolutions = () => {
    if (allSolutions.length > MAX_SOLUTIONS_IN_MEMORY * 2) {
      allSolutions.sort((a, b) => b.score - a.score);
      allSolutions.length = MAX_SOLUTIONS_IN_MEMORY;
    }
  };

  // Branch and Bound: 現在の最良スコアを追跡
  let globalBestScore = 0;

  // 紋章をPareto支配でフィルタリング（依存ステータスのみで比較）
  const emblemsForSearch = filterDominatedEmblems(emblems, relevantStats);

  // ルーンストーン探索の準備
  const enableRunestoneSearch = options?.enableRunestoneSearch ?? false;
  let runestoneCombs: RunestoneCombination[] = [];
  if (enableRunestoneSearch && gameData.runestones && gameData.runestones.length > 0) {
    runestoneCombs = buildRunestoneCombinations(gameData.runestones, relevantStats);
    console.log(`[Optimize] Runestone search enabled: ${runestoneCombs.length} combinations to evaluate`);
  } else {
    // ルーンストーン探索無効の場合は固定値を使用
    runestoneCombs = [{ runestones: [], totalBonus: options?.runestoneBonus || {} }];
  }

  // 枝刈りカウンター
  let prunedEmblems = 0;
  let prunedRunestones = 0;

  // 進捗計算用
  const totalIterations = runestoneCombs.length * Math.max(emblemsForSearch.length, 1);
  let completedIterations = 0;

  // ルーンストーン探索ループ
  for (let runeIndex = 0; runeIndex < runestoneCombs.length; runeIndex++) {
    const runeComb = runestoneCombs[runeIndex];

    // ルーンストーンボーナスをコンテキストに反映
    const runeContext = { ...context, runestoneBonus: runeComb.totalBonus };

    // Branch and Bound: 枝刈り（グローバルベストの50%未満ならスキップ）
    if (enableRunestoneSearch && globalBestScore > 0 && runeIndex > 5) {
      // 上位5つ以降は枝刈り対象
      // ルーンストーンの貢献度を概算
      const runeContribution = Object.values(runeComb.totalBonus).reduce((sum: number, v) => sum + (v as number || 0), 0);
      const bestRuneContribution = Object.values(runestoneCombs[0].totalBonus).reduce((sum: number, v) => sum + (v as number || 0), 0);
      if (runeContribution < bestRuneContribution * 0.5) {
        prunedRunestones++;
        completedIterations += Math.max(emblemsForSearch.length, 1);
        continue;
      }
    }

    if (emblemsForSearch.length > 0) {
      // 紋章で探索（常に自動選択）
      let emblemIdx = 0;
      for (const emblem of emblemsForSearch) {
        emblemIdx++;
        completedIterations++;

        // 進捗更新（5%刻みで報告）
        const progressPercent = Math.floor((completedIterations / totalIterations) * 40) + 40; // 40-80%
        if (completedIterations % Math.max(1, Math.floor(totalIterations / 20)) === 0) {
          reportProgress('local_search', progressPercent, 100, `ルーン${runeIndex + 1}/${runestoneCombs.length} × 紋章${emblemIdx}/${emblemsForSearch.length} (計${completedIterations}/${totalIterations})`, globalBestScore, currentBestSolution);
        }

        // UIスレッド解放（5個ごと）
        if (emblemIdx % 5 === 0) {
          await new Promise(resolve => setTimeout(resolve, 0));
        }

        const emblemContext = { ...runeContext, emblem };

        // キャッシュキー用コンテキスト識別子
        const contextKey = `rune${runeIndex}:emblem${emblemIdx}`;

        if (useExhaustiveSearch) {
          // 全探索を使用（最適解を保証）
          const exhaustiveResults = await exhaustiveSearchAsync(pool, emblemContext, gameData.eqConst, constraints.maxResults || 10);
          for (const sol of exhaustiveResults) {
            const solutionWithMeta = { ...sol, usedEmblem: emblem, usedRunestones: runeComb };
            allSolutions.push(solutionWithMeta);
            if (sol.score > globalBestScore) {
              globalBestScore = sol.score;
              currentBestSolution = solutionWithMeta;
              // 動的ステータス更新：ベスト装備のステータスで重み計算を更新
              if (sol.stats) {
                setCurrentOptimizationStats(sol.stats);
              }
            }
          }
        } else {
          // Phase 1: Multi-Start Greedy + Crossoverを使用
          const multiStartSolutions = await multiStartGreedyAsync(pool, emblemContext, gameData.eqConst, contextKey);

          // 最良の初期解でローカルサーチをスキップするか判定
          const bestInitialSolution = multiStartSolutions[0];
          if (!bestInitialSolution) {
            prunedEmblems++;
            continue;
          }

          // 初期解が現在の最良スコアの60%未満なら、ローカルサーチをスキップ（計算量削減）
          // Phase 2: 閾値を0.7→0.6に緩和して、より多くの紋章候補を探索
          if (globalBestScore > 0 && bestInitialSolution.score < globalBestScore * 0.6) {
            prunedEmblems++;
            continue;
          }

          // 上位2つの初期解をローカルサーチで改善
          const solutionsToImprove = multiStartSolutions.slice(0, 2);
          for (const initialSolution of solutionsToImprove) {
            const improvedSolution = await localSearchAsync(
              initialSolution, pool, emblemContext, gameData.eqConst, 50, contextKey
            );

            // 最低必須ステータスを満たす解のみ追加
            if (improvedSolution.score > 0) {
              const solutionWithMeta = { ...improvedSolution, usedEmblem: emblem, usedRunestones: runeComb };
              allSolutions.push(solutionWithMeta);

              // 最良スコアを更新
              if (improvedSolution.score > globalBestScore) {
                globalBestScore = improvedSolution.score;
                currentBestSolution = solutionWithMeta;
                // 動的ステータス更新：ベスト装備のステータスで重み計算を更新
                if (improvedSolution.stats) {
                  setCurrentOptimizationStats(improvedSolution.stats);
                }
              }
            }
          }
        }
      }
    } else {
      // 紋章なしで探索
      completedIterations++;

      // 進捗更新
      const progressPercent = Math.floor((completedIterations / totalIterations) * 40) + 40;
      reportProgress('local_search', progressPercent, 100, `ルーン${runeIndex + 1}/${runestoneCombs.length} × 紋章なし (計${completedIterations}/${totalIterations})`, globalBestScore, currentBestSolution);

      // キャッシュキー用コンテキスト識別子
      const contextKey = `rune${runeIndex}:noemblem`;

      if (useExhaustiveSearch) {
        // 全探索を使用
        const exhaustiveResults = await exhaustiveSearchAsync(pool, runeContext, gameData.eqConst, constraints.maxResults || 10);
        for (const sol of exhaustiveResults) {
          const solutionWithMeta = { ...sol, usedEmblem: null as EmblemData | null, usedRunestones: runeComb };
          allSolutions.push(solutionWithMeta);
          if (sol.score > globalBestScore) {
            globalBestScore = sol.score;
            currentBestSolution = solutionWithMeta;
            // 動的ステータス更新：ベスト装備のステータスで重み計算を更新
            if (sol.stats) {
              setCurrentOptimizationStats(sol.stats);
            }
          }
        }
      } else {
        // Phase 1: Multi-Start Greedy + Crossoverを使用
        const multiStartSolutions = await multiStartGreedyAsync(pool, runeContext, gameData.eqConst, contextKey);

        // 上位2つの初期解をローカルサーチで改善
        const solutionsToImprove = multiStartSolutions.slice(0, 2);
        for (const initialSolution of solutionsToImprove) {
          const improvedSolution = await localSearchAsync(
            initialSolution, pool, runeContext, gameData.eqConst, 50, contextKey
          );
          if (improvedSolution.score > 0) {
            const solutionWithMeta = { ...improvedSolution, usedEmblem: null as EmblemData | null, usedRunestones: runeComb };
            allSolutions.push(solutionWithMeta);

            // 最良スコアを更新
            if (improvedSolution.score > globalBestScore) {
              globalBestScore = improvedSolution.score;
              currentBestSolution = solutionWithMeta;
              // 動的ステータス更新：ベスト装備のステータスで重み計算を更新
              if (improvedSolution.stats) {
                setCurrentOptimizationStats(improvedSolution.stats);
              }
            }
          }
        }
      }
    }

    // ルーンストーンループごとにUIスレッド解放 + メモリ管理
    trimSolutions();
    await new Promise(resolve => setTimeout(resolve, 0));
  }

  console.log(`[Optimize] B&B pruning: ${prunedEmblems} emblem, ${prunedRunestones} runestone evaluations skipped`);

  // スコアでソート
  allSolutions.sort((a, b) => b.score - a.score);
  console.log('[Optimize] Solutions after emblem search:', allSolutions.length);

  reportProgress('finalizing', 80, 100, '多様な解を生成中...');

  // 多様な解を生成（既存の解に追加）
  // 各解に異なるルーンストーン/紋章の組み合わせを割り当て
  const diverseResults = await generateDiverseSolutionsAsync(
    pool,
    context,
    gameData.eqConst,
    constraints.maxResults || 10
  );

  // 多様な解に対して、異なるルーンストーン組み合わせを割り当て
  // allSolutionsから使用済みのルーンストーン組み合わせを取得し、循環させる
  const usedRunestonePatterns = allSolutions
    .filter(s => s.usedRunestones)
    .map(s => s.usedRunestones!);
  const usedEmblemPatterns = allSolutions
    .filter(s => s.usedEmblem)
    .map(s => s.usedEmblem!);

  const diverseSolutions = diverseResults.map((sol, idx) => {
    // 異なるルーンストーン/紋章パターンを循環して割り当て
    const runeIndex = idx % Math.max(usedRunestonePatterns.length, 1);
    const emblemIndex = idx % Math.max(usedEmblemPatterns.length, 1);
    return {
      ...sol,
      usedEmblem: usedEmblemPatterns[emblemIndex] || null,
      usedRunestones: usedRunestonePatterns[runeIndex] || undefined,
    };
  });

  // 既存の解と統合してスコアでソート（メモリ節約のため上位のみ処理）
  const combinedSolutions = [...allSolutions, ...diverseSolutions];
  combinedSolutions.sort((a, b) => b.score - a.score);
  const limitedSolutions = combinedSolutions.slice(0, MAX_SOLUTIONS_IN_MEMORY);

  // 支配性チェック：明らかに劣るビルドを除去
  const nonDominatedSolutions = filterDominatedBuilds(limitedSolutions);
  console.log(`[Optimize] After dominance filtering: ${nonDominatedSolutions.length} solutions`);

  // 重複を除去して上位N件を取得
  const seenKeys = new Set<string>();
  const solutions: (ScoredCombination & {
    usedEmblem?: EmblemData | null;
    usedRunestones?: RunestoneCombination;
  })[] = [];

  // 警告メッセージを収集
  const warnings: string[] = [];

  // まずスコア > 0 の結果を収集
  for (const sol of nonDominatedSolutions) {
    // 装備名+EX+紋章+ルーンストーンでユニークキーを生成
    const equipmentKey = Object.entries(sol.equipmentSet).map(([slot, e]) => {
      if (!e) return `${slot}:null`;
      const configIdx = sol.configIndices[slot as EquipSlot] || 0;
      const config = e.configurations[configIdx];
      const exStr = config?.exStats ? `${config.exStats.ex1}-${config.exStats.ex2 || ''}` : '';
      return `${slot}:${e.name}:${exStr}`;
    }).join('|');
    // 紋章とルーンストーンもキーに含める
    const emblemKey = sol.usedEmblem?.アイテム名 || 'noEmblem';
    const runeKey = sol.usedRunestones?.runestones?.map(r => r.name).join(',') || 'noRunes';
    const key = `${equipmentKey}||${emblemKey}||${runeKey}`;
    if (!seenKeys.has(key) && sol.score > 0) {
      seenKeys.add(key);
      solutions.push(sol);
      if (solutions.length >= (constraints.maxResults || 10)) break;
    }
  }

  // スコア > 0 の結果がない場合、最低必須ステータスを満たせなかった可能性
  // 最低必須ステータスの条件を緩和して参考結果を返す
  if (solutions.length === 0 && nonDominatedSolutions.length > 0) {
    // 最低必須ステータスが設定されている場合
    const hasMinimumStats = options?.minimumStats &&
      Object.values(options.minimumStats).some(v => v !== undefined && v > 0);

    if (hasMinimumStats) {
      warnings.push('指定された最低必須ステータスを満たす装備構成が見つかりませんでした。条件を緩和するか、別の防具タイプを検討してください。');
      console.log('[Optimize] No solutions meet minimum stats requirements. Adding warning.');
    } else {
      warnings.push('有効な装備構成が見つかりませんでした。');
    }
  }

  console.log('[Optimize] Generated solutions count:', solutions.length);
  if (solutions.length > 0) {
    console.log('[Optimize] Best solution score:', solutions[0].score);
    const bestEquipment = solutions[0].equipmentSet;
    const equipmentNames = Object.keys(bestEquipment).map(slot => {
      const eq = bestEquipment[slot as EquipSlot];
      return `${slot}: ${eq?.name || 'none'}`;
    });
    console.log('[Optimize] Best solution equipment:', equipmentNames);
  }

  reportProgress('completed', 100, 100, '完了');

  // 結果を変換（紋章とSPパターン情報を含む）
  const results: OptimizeResult[] = solutions.map((solution, index) => {
    // 装備セットを構築
    const equipment: Record<string, any> = {};
    const slots: EquipSlot[] = ['weapon', 'head', 'body', 'leg', 'accessory1', 'accessory2'];

    for (const slot of slots) {
      const candidate = solution.equipmentSet[slot];
      if (candidate) {
        const configIndex = solution.configIndices[slot] || 0;
        const config = candidate.configurations[configIndex];

        equipment[slot] = {
          name: candidate.name,
          type: candidate.type,
          sourceData: candidate.sourceData,
          configuration: config,
          stats: calculateEquipmentStatsFn(candidate, configIndex, gameData.eqConst, context.relevantStats),
        };
      }
    }

    // DEBUG: 装備構成を確認
    if (index === 0) {
      console.log('[Optimize] Result equipment keys:', Object.keys(equipment));
      console.log('[Optimize] Result equipment:', JSON.stringify(equipment, null, 2).substring(0, 500));
    }

    return {
      rank: index + 1,
      build: currentBuild,
      equipment,
      expectedDamage: solution.score,
      calculatedStats: solution.stats,
      damageDetails: {
        baseDamage: solution.score,
        critRate: solution.stats.CritRate || 0,
        hitRate: 100,
      },
      // 紋章情報を追加
      selectedEmblem: solution.usedEmblem || null,
      // ルーンストーン情報を追加
      selectedRunestones: solution.usedRunestones ? {
        runestones: solution.usedRunestones.runestones.map(r => ({
          name: r.name || r['アイテム名（・<グレード>）は不要'],
          grade: r.グレード,
        })),
        totalBonus: solution.usedRunestones.totalBonus,
      } : null,
    };
  });

  // 探索統計を計算
  const elapsedTime = Date.now() - startTime;
  const totalPruned = prunedEmblems + prunedRunestones;
  const searchStats: SearchStats = {
    totalCandidates,
    evaluatedCombinations: allSolutions.length,
    prunedCombinations: totalPruned,
    elapsedTime,
    phase: 'completed',
  };

  console.log(`[Optimize] Total evaluated: ${allSolutions.length}, Pruned: ${totalPruned} (${prunedEmblems} emblems, ${prunedRunestones} runestones)`);

  console.log('[Optimize] Search stats:', searchStats);

  // 最適化終了時: 最終結果のステータスを保持（クリアしない）
  // これにより、重み表示が最終結果に基づいたものになる
  // 次の最適化開始時にクリアされる

  return { results, searchStats, warnings: warnings.length > 0 ? warnings : undefined };
}

/**
 * CSV出力用のデータを生成
 */
export function generateOptimizeResultCSV(results: OptimizeResult[]): string {
  if (results.length === 0) return '';

  const headers = ['順位', '期待ダメージ', '力', '魔力', '体力', '素早さ', '会心率', '会心ダメージ'];
  const rows = results.map((r) => [
    r.rank,
    Math.round(r.expectedDamage),
    r.calculatedStats.Power || 0,
    r.calculatedStats.Magic || 0,
    r.calculatedStats.HP || 0,
    r.calculatedStats.Agility || 0,
    r.calculatedStats.CritRate || 0,
    r.calculatedStats.CritDamage || 0,
  ]);

  return [headers.join(','), ...rows.map((row) => row.join(','))].join('\n');
}
